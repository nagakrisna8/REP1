import React, { memo, useEffect, useRef, useState } from "react";
import {
  Grid as DataGrid,
  GridCellProps,
  GridColumn,
  GridColumnMenuFilter,
  GridColumnMenuProps,
  GridToolbar
} from "@progress/kendo-react-grid";
import { getter, process } from "@progress/kendo-data-query";
import { Button, Card, MenuItem, Select, TextField, Typography } from "@mui/material";
import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import SettingsIcon from "@mui/icons-material/Settings";
import ArrowUpwardIcon from "@mui/icons-material/ArrowUpward";
import ArrowDownwardIcon from "@mui/icons-material/ArrowDownward";
import SortIcon from "@mui/icons-material/Sort";
import { filterIcon } from "@progress/kendo-svg-icons";

import { OrganizationTypeMasterTable, SortByData } from "../AdminModal";

const AnyGrid = DataGrid as any;

const editField = "inEdit";
const SELECTED_FIELD = "selected";

const GridFilterMenuWithoutSort = (props: GridColumnMenuProps) => (
  <GridColumnMenuFilter {...props} expanded />
);

interface Props {
  KEY: string;
  organizationTypeData: OrganizationTypeMasterTable[];
  dataState: any;
  columnPropsBuilder: (field: any) => any;
  dataStateChange: any;
  itemChange: any;
  createOrganizationType: () => void;
  saveOrganizationType: () => void;
  dragStart: (dataItem: OrganizationTypeMasterTable) => void;
  reorder: (dataItem: OrganizationTypeMasterTable) => void;
  sortBy: "custom" | "asc" | "desc" | undefined;
  handleSortByChange: (
    key: keyof SortByData,
    value: "custom" | "asc" | "desc"
  ) => void;
}

const OrganizationTypeNameCell = (props: GridCellProps) => {
  const { dataItem, field = "" } = props;
  const value = dataItem[field] ?? "";

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    props.onChange?.({
      dataIndex: props.dataIndex,
      dataItem: { ...dataItem, ORGTYPE: e.target.value },
      field,
      syntheticEvent: e,
      value: e.target.value
    });
  };

  return (
    <td title={value}>
      <TextField fullWidth value={value} onChange={handleChange} />
    </td>
  );
};

const ActiveCheckboxCell = (props: GridCellProps) => {
  const { dataItem } = props;

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    props.onChange?.({
      dataIndex: props.dataIndex,
      dataItem: { ...dataItem, ISACTIVE: e.target.checked },
      field: props.field,
      syntheticEvent: e,
      value: e.target.checked
    });
  };

  return (
    <td title={dataItem.ISACTIVE ? "True" : "False"}>
      <div style={{ display: "flex", justifyContent: "center" }}>
        <input
          type="checkbox"
          checked={dataItem.ISACTIVE}
          onChange={handleChange}
          style={{ cursor: "pointer" }}
        />
      </div>
    </td>
  );
};

const DragCell = ({ dataItem, ...props }: GridCellProps) => {
  const { dragStart, reorder } = props as any;

  return (
    <td
      onDragOver={(e) => {
        e.preventDefault();
        reorder(dataItem);
      }}
    >
      <span
        draggable
        style={{ cursor: "move", display: "flex", justifyContent: "center" }}
        onDragStart={(e) => {
          dragStart(dataItem);
          e.dataTransfer.setData("dragging", "");
        }}
      >
        <SortIcon />
      </span>
    </td>
  );
};

const OrganizationTypeTable: React.FC<Props> = memo((props) => {
  const gridRef = useRef<any>(null);
  const idGetter = getter(props.KEY);

  const [dynamicWidth, setDynamicWidth] = useState(0);
  const [fixedWidth, setFixedWidth] = useState(0);

  useEffect(() => {
    if (!gridRef.current) return;

    const headers = gridRef.current.element.querySelectorAll(".k-header");
    let fixed = 0;
    let dynamic = 0;

    headers.forEach((cell: any, index: number) => {
      const column = gridRef.current.columns[index];

      if (column.width?.toString().includes("px")) {
        fixed += parseInt(column.width);
      } else {
        dynamic += column.width || 0;
      }

      cell.title = column.title;
    });

    setFixedWidth(fixed);
    setDynamicWidth(dynamic);
  }, []);

  const setPercentage = (minWidth = 200) => {
    const gridWidth =
      document.querySelector("#kgrid-oss-checklistType")?.clientWidth || 0;

    if (gridWidth <= 1250) return minWidth;

    const availableWidth = gridWidth - fixedWidth;
    return Math.max(minWidth, availableWidth - dynamicWidth);
  };

  return (
    <div style={{ paddingBottom: 20 }}>
      <Card style={{ borderLeft: "4px solid #0033A1", marginLeft: 22 }}>
        <AnyGrid
          id="kgrid-oss-checklistType"
          ref={gridRef}
          style={{ height: "60vh", minHeight: 400 }}
          data={process(props.organizationTypeData, props.dataState).data}
          dataItemKey={props.KEY}
          selectedField={SELECTED_FIELD}
          editField={editField}
          rowHeight={30}
          resizable
          sortable={false}
          scrollable="scrollable"
          columnMenuIcon={filterIcon}
          onItemChange={props.itemChange}
          onDataStateChange={props.dataStateChange}
          {...props.dataState}
        >
          <GridToolbar>
            <div
              style={{
                display: "flex",
                justifyContent: "space-between",
                width: "100%"
              }}
            >
              <div style={{ display: "flex", gap: 8 }}>
                <Button
                  startIcon={<AddCircleOutlineIcon />}
                  onClick={props.createOrganizationType}
                  variant="outlined"
                  size="small"
                >
                  Create New
                </Button>

                <Button
                  onClick={props.saveOrganizationType}
                  variant="outlined"
                  size="small"
                >
                  Save
                </Button>
              </div>

              <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                <Typography>Sort Order :</Typography>

                <Select
                  value={props.sortBy || "custom"}
                  style={{ width: 180 }}
                  onChange={(e) =>
                    props.handleSortByChange(
                      "organizationType",
                      e.target.value as "custom" | "asc" | "desc"
                    )
                  }
                >
                  <MenuItem value="custom">
                    <SettingsIcon sx={{ mr: 1 }} /> Customize
                  </MenuItem>

                  <MenuItem value="asc">
                    <ArrowUpwardIcon sx={{ mr: 1 }} />
                    Ascending
                  </MenuItem>

                  <MenuItem value="desc">
                    <ArrowDownwardIcon sx={{ mr: 1 }} />
                    Descending
                  </MenuItem>
                </Select>
              </div>
            </div>
          </GridToolbar>

          <GridColumn
            title="Sort"
            cells={{ data: (p) => <DragCell {...p} {...props} /> }}
            width="90px"
          />

          <GridColumn
            {...props.columnPropsBuilder("ORGTYPE")}
            title="Organization Type"
            cells={{ data: OrganizationTypeNameCell }}
            width={setPercentage(272)}
            columnMenu={GridFilterMenuWithoutSort}
          />

          <GridColumn
            {...props.columnPropsBuilder("ISACTIVE")}
            title="Active"
            cells={{ data: ActiveCheckboxCell }}
            width="165px"
            columnMenu={GridFilterMenuWithoutSort}
          />
        </AnyGrid>
      </Card>
    </div>
  );
});

export default OrganizationTypeTable;
