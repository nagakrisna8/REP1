.focal-grid-compact {
  --kendo-grid-row-hover-bg: #ffffff;
  --kendo-table-hover-bg: #ffffff;
}
  .tabBox:has(.gridSupplementaryContainer) {
    padding: 20px 0px;
  }

  .categorychecklistHeaderGridContainer {
    margin-top: 16px;
  }

  .MuiAlert-filledSuccess {
    background-color: #81bc00 !important;
  }

  .Savebtn {
    text-transform: none;
    align-items: center;
    height: 32px;
  }

  .CancelBtn {
    text-transform: none;
    height: 32px;
    align-items: center;
  }

  .k-grid tr.k-selected,
  .k-grid tr.k-state-selected,
  .k-grid tr.k-focus {
    background-color: transparent !important;
  }

  .k-grid td.k-focus {
    box-shadow: none !important;
    background-color: transparent !important;
  }

  #kgrid-oss-checklistType,
  #kgrid-oss-admin-table-errorCode1,
  #kgrid-oss-admin-table-errorCode1-itar,
  #kgrid-oss-admin-table-errorCode2,
  #kgrid-oss-admin-table-errorCode3,
  #kgrid-oss-admin-table-category,
  #kgrid-oss-admin-table-category-type,
  #kgrid-oss-admin-table-reasonCode,
  #kgrid-oss-admin-table-reasonCode-itar {
    .k-table {
      width: 100% !important;
    }

    td,
    th {
      color: $text-default;
    }

    th {
      // background-color: $table-header-bg;
      margin: 0 !important;
      padding-block: 0 !important;
      height: $table-row-height !important;

      .k-cell-inner,
      .k-checkbox-wrap {
        margin: 0 !important;
        margin-block: 0 !important;
        margin-inline: 0 !important;
      }

      .k-checkbox-wrap {
        margin: 0 0 7px -9px !important;
        width: 100%;
        display: flex;
        justify-content: center;
      }
    }

    .k-table-alt-row {
      background-color: $table-bg-alt-row !important;
    }

    tbody .checkbox-background {
      display: flex;
      justify-content: center;

      input {
        margin-left: 0 !important;
      }
    }

    tbody tr:hover {
      background-color: $table-row-bg-hover !important;
    }

    tbody tr td {
      box-sizing: border-box !important;
      border-bottom: 1px solid $table-row-border-col !important;
      padding: 0 8px !important;
      height: $table-row-height !important;
      padding-block: 0 !important;

      .Mui-error>fieldset {
        border-color: #ea002a !important;
      }
    }

    .k-toolbar.k-grid-toolbar button.k-table-row .MuiTypography-button {
      padding-top: 2px;
    }
  }

  .k-button-md.k-icon-button {
    display: none !important;
  }

  .k-button .k-button-md .k-button-solid .k-button-solid-base .k-rounded-md .k-icon-button .k-toolbar-prev .k-disabled {
    display: none !important;
  }

  .k-button .k-button-md .k-button-solid .k-button-solid-base .k-rounded-md .k-icon-button .k-toolbar-next {
    display: none !important;
  }

  .k-toolbar-separator .k-separator .k-toolbar-button-separator {
    display: none !important;
  }

  .kgrid-oss-checklistType>.k-cell-inner>.k-link,
  .kgrid-oss-admin-table-errorCode1>.k-cell-inner>.k-link,
  .kgrid-oss-admin-table-errorCode1-itar>.k-cell-inner>.k-link {
    height: $table-row-height !important;
    padding: 0 !important;

    >.k-column-title {
      display: flex !important;
      align-items: center !important;
      justify-content: flex-start !important;
      height: 100% !important;
      width: 100% !important;
    }
  }

  input[type="checkbox"]:disabled {
    opacity: 1 !important;
  }
}

