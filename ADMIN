import "./AdminTable.scss";
import { MenuItem, Select, SelectChangeEvent } from "@mui/material";
import React, { useEffect, useState } from "react";
import {
  OrganizationTypeMasterTable,
  SupplierActivityMasterTable,
  SupplierCategoryMasterTable,
  OrganizationTableData,
  MasterDataItem,
  GetAdminSortByResponse,
  SortByData
} from "./AdminModal";

import EasaListService from "../EasaRegisterListService";
import { useDispatch } from "react-redux";
import { State } from "@progress/kendo-data-query";
import {
  GridColumnMenuFilter,
  GridColumnMenuSort,
  GridDataStateChangeEvent,
  GridItemChangeEvent,
  isColumnMenuFilterActive,
  isColumnMenuSortActive
} from "@progress/kendo-react-grid";
import * as _ from "lodash";
import { showSnackbar } from "../../../../core/snackbar/CustomSnackBarSlice";
import StorageService from "../../../../../utils/StorageService";
import EnvDetail from "../../../../../utils/EnvDetail";

import OrganizationTypeTable from "./OrganizationType/OrganizationTypeTable";
import SupplierActivityTable from "./SupplierActivity/SupplierActivityTable";
import SupplierCategoryTable from "./SupplierCategory/SupplierCategoryTable";
import OrganizationTable from "./Organization/OrganizationTable.Component";

/* ------------------------------ CONSTANTS ------------------------------ */

const ORGANIZATION_TYPE_DATA_ITEM_KEY = "ORGANIZATIONTYPEID";
const SUPPLIER_ACTIVITY_DATA_ITEM_KEY = "ID";
const SUPPLIER_CATEGORY_DATA_ITEM_KEY = "CATEGORYID";
const ORGANIZATION_DATA_ITEM_KEY = "ORGANIZATIONID";

/* ------------------------------ HELPERS ------------------------------ */

const ColumnMenuBuilder = (props) => (
  <div>
    <GridColumnMenuSort {...props} />
    <GridColumnMenuFilter {...props} expanded />
  </div>
);

const updateGridRow = (data: any[], idKey: string, event: GridItemChangeEvent) =>
  data.map((item) =>
    item[idKey] === event.dataItem[idKey]
      ? { ...item, [event.field as string]: event.value }
      : item
  );

const reorderRows = (data: any[], activeItem: any, targetItem: any) => {
  if (!activeItem || activeItem === targetItem) return data;

  const reorderData = [...data];
  const prevIndex = reorderData.findIndex((p) => p === activeItem);
  const nextIndex = reorderData.findIndex((p) => p === targetItem);

  reorderData.splice(prevIndex, 1);
  reorderData.splice(nextIndex, 0, activeItem);

  let order = 1;
  reorderData.forEach((row) => (row.SORT_ORDER = order++));

  return reorderData;
};

const buildPayload = (
  current: any[],
  original: any[],
  idKey: string,
  nameKey: string,
  descKey?: string,
  orgTypeId: number = 0
) => {
  const items: MasterDataItem[] = [];

  current.forEach((row) => {
    const originalRow = original.find((o) => o[idKey] === row[idKey]);

    if (!originalRow) {
      items.push({
        Id: 0,
        OperationType: "add",
        Name: row[nameKey]?.trim() || "",
        Description: row[descKey]?.trim() || "",
        IsActive: row.ISACTIVE ? "Y" : "N",
        Notes: "",
        Address: "",
        Department: "",
        Phone: "",
        Email: "",
        Title: "",
        orgTypeId
      });
    } else if (JSON.stringify(originalRow) !== JSON.stringify(row)) {
      items.push({
        Id: row[idKey],
        OperationType: "update",
        Name: row[nameKey]?.trim() || "",
        Description: row[descKey]?.trim() || "",
        IsActive: row.ISACTIVE ? "Y" : "N",
        Notes: "",
        Address: "",
        Department: "",
        Phone: "",
        Email: "",
        Title: "",
        orgTypeId
      });
    }
  });

  return items;
};

const sortRows = (data: any[], field: string, order: "asc" | "desc") => {
  const sorted = _.orderBy(data, [field], [order]);
  let i = 1;
  return sorted.map((x) => ({ ...x, SORT_ORDER: i++ }));
};

const isColumnActive = (field, dataState) =>
  isColumnMenuFilterActive(field, dataState.filter) ||
  isColumnMenuSortActive(field, dataState.sort);

/* ------------------------------ COMPONENT ------------------------------ */

const Options = [
  "Organization Type",
  "Organization",
  "Supplier Category",
  "Supplier Activity Authorized"
];

type TableMaintenancePage =
  | "Organization Type"
  | "Organization"
  | "Supplier Category"
  | "Supplier Activity Authorized";

const TableMaintenance: React.FC = () => {
  const dispatch = useDispatch();

  const [selectedPage, setSelectedPage] =
    useState<TableMaintenancePage>("Organization Type");

  const [dirtyFlag, setDirtyFlag] = useState(false);
  const [selectedOrgId, setSelectedOrgId] = useState<number>(1);

  /* ------------------------------ DATA STATES ------------------------------ */

  const [organizationTypeData, setOrganizationTypeData] = useState<
    OrganizationTypeMasterTable[]
  >([]);
  const [organizationData, setOrganizationData] =
    useState<OrganizationTableData[]>([]);
  const [supplierCategoryData, setSupplierCategoryData] =
    useState<SupplierCategoryMasterTable[]>([]);
  const [supplierActivityData, setSupplierActivityData] =
    useState<SupplierActivityMasterTable[]>([]);

  const [originalOrganizationTypeData, setOriginalOrganizationTypeData] =
    useState<OrganizationTypeMasterTable[]>([]);
  const [originalOrganizationData, setOriginalOrganizationData] =
    useState<OrganizationTableData[]>([]);
  const [originalSupplierCategoryData, setOriginalSupplierCategoryData] =
    useState<SupplierCategoryMasterTable[]>([]);
  const [originalSupplierActivityData, setOriginalSupplierActivityData] =
    useState<SupplierActivityMasterTable[]>([]);

  const [organizationTypeState, setOrganizationTypeState] =
    useState<State>({});
  const [organizationState, setOrganizationState] = useState<State>({});
  const [supplierCategoryState, setSupplierCategoryState] =
    useState<State>({});
  const [supplierActivityState, setSupplierActivityState] =
    useState<State>({});

  /* ------------------------------ GRID HANDLERS ------------------------------ */

  const organizationItemChange = (e: GridItemChangeEvent) => {
    setOrganizationData(
      updateGridRow(organizationData, ORGANIZATION_DATA_ITEM_KEY, e)
    );
    setDirtyFlag(true);
  };

  const supplierActivityItemChange = (e: GridItemChangeEvent) => {
    setSupplierActivityData(
      updateGridRow(supplierActivityData, SUPPLIER_ACTIVITY_DATA_ITEM_KEY, e)
    );
    setDirtyFlag(true);
  };

  const supplierCategoryItemChange = (e: GridItemChangeEvent) => {
    setSupplierCategoryData(
      updateGridRow(supplierCategoryData, SUPPLIER_CATEGORY_DATA_ITEM_KEY, e)
    );
    setDirtyFlag(true);
  };

  const organizationTypeItemChange = (e: GridItemChangeEvent) => {
    setOrganizationTypeData(
      updateGridRow(organizationTypeData, ORGANIZATION_TYPE_DATA_ITEM_KEY, e)
    );
    setDirtyFlag(true);
  };

  /* ------------------------------ SAVE FUNCTIONS ------------------------------ */

  const saveOrganizationType = async () => {
    const items = buildPayload(
      organizationTypeData,
      originalOrganizationTypeData,
      "ORGANIZATIONTYPEID",
      "ORGANIZATIONTYPE"
    );

    if (!items.length) {
      dispatch(
        showSnackbar({
          snackbarOpen: true,
          snackbarType: "error",
          snackbarMessage: "No changes detected."
        })
      );
      return;
    }

    await EasaListService.addMasterDataType({
      MasterDataType: "OrganizationType",
      Items: items
    });

    setDirtyFlag(false);
  };

  const saveOrganization = async () => {
    const items = buildPayload(
      organizationData,
      originalOrganizationData,
      "ORGANIZATIONID",
      "ORGANIZATIONNAME",
      "ORGANIZATIONDESCRIPTION",
      selectedOrgId
    );

    if (!items.length) return;

    await EasaListService.addMasterDataType({
      MasterDataType: "Organization",
      Items: items
    });

    setDirtyFlag(false);
  };

  /* ------------------------------ EFFECTS ------------------------------ */

  useEffect(() => {
    const storageService = new StorageService();
    storageService.setApplicationDataByKey(
      `${EnvDetail.ParentAppName}-${EnvDetail.AppName}`,
      "IsTabDirty",
      dirtyFlag
    );
  }, [dirtyFlag]);

  /* ------------------------------ UI ------------------------------ */

  return (
    <div className="EASA-Admin-table-maintenance">
      <div className="EASA-Admin-table-maintenance-topbar">
        <div>Master Data</div>

        <Select value={selectedPage} onChange={(e) => setSelectedPage(e.target.value as any)}>
          {Options.map((item) => (
            <MenuItem key={item} value={item}>
              {item}
            </MenuItem>
          ))}
        </Select>
      </div>

      <div className="EASA-Admin-table-maintenance-section">

        {selectedPage === "Organization Type" && (
          <OrganizationTypeTable
            KEY={ORGANIZATION_TYPE_DATA_ITEM_KEY}
            organizationTypeData={organizationTypeData}
            dataState={organizationTypeState}
            itemChange={organizationTypeItemChange}
            saveOrganizationType={saveOrganizationType}
          />
        )}

        {selectedPage === "Organization" && (
          <OrganizationTable
            KEY={ORGANIZATION_DATA_ITEM_KEY}
            organizationData={organizationData}
            dataState={organizationState}
            itemChange={organizationItemChange}
            saveOrganization={saveOrganization}
          />
        )}

        {selectedPage === "Supplier Category" && (
          <SupplierCategoryTable
            KEY={SUPPLIER_CATEGORY_DATA_ITEM_KEY}
            supplierCategoryData={supplierCategoryData}
            dataState={supplierCategoryState}
            itemChange={supplierCategoryItemChange}
          />
        )}

        {selectedPage === "Supplier Activity Authorized" && (
          <SupplierActivityTable
            KEY={SUPPLIER_ACTIVITY_DATA_ITEM_KEY}
            supplierActivityData={supplierActivityData}
            dataState={supplierActivityState}
            itemChange={supplierActivityItemChange}
          />
        )}
      </div>
    </div>
  );
};

export default TableMaintenance;
