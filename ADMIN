// constants

const ORGANIZATION_TYPE_DATA_ITEM_KEY: string = "ORGANIZATIONTYPEID";
const SUPPLIER_ACTIVITY_DATA_ITEM_KEY: string = "ACTIVITYID";
const ORGANIZATION_DATA_ITEM_KEY = "ORGANIZATIONID";
const FOCAL_DATA_ITEM_KEY = "ID";
const SUPPLIER_CATEGORY_DATA_ITEM_KEY: string = "CATEGORYID";
// kendo grid utilities
const ColumnMenuBuilder = (props) => {
    return (
        <div>
            <GridColumnMenuSort {...props} />
            <GridColumnMenuFilter {...props} expanded={true} />
        </div>
    );
};

interface MasterDataPayload {
    MasterDataType: string;
    Items: MasterDataItem[]
}
const isColumnActive = (field, dataState) => {
    return isColumnMenuFilterActive(field, dataState.filter) || isColumnMenuSortActive(field, dataState.sort);
};
type TableMaintenancePage = AdminTableEnum.ORGANIZATIONTYPE | AdminTableEnum.ORGANIZATION | AdminTableEnum.SUPPLIERCATEGORY | AdminTableEnum.SUPPLIERACTIVITY | AdminTableEnum.FOCALMANAGEMENT;
const TableMaintenance: React.FC = () => {
    const dispatch = useDispatch();
    const [sortBy, setSortBy] = useState<SortByData>({
        organization: AdminTableEnum.CUSTOM,
        organizationType: AdminTableEnum.CUSTOM,
        supplierCategory: AdminTableEnum.CUSTOM,
        supplierActivity: AdminTableEnum.CUSTOM,
        focal: AdminTableEnum.CUSTOM
    });
    const [selectedOrgId, setSelectedOrgId] = useState<number | "">("");
    const [selectedOrganizationId, setSelectedOrganizationId] = useState<number | "">("");
    const [masterDataOptions, setMasterDataOptions] = useState<any[]>([]);
    const [selectedPage, setSelectedPage] = useState<TableMaintenancePage>(AdminTableEnum.ORGANIZATIONTYPE);
    const [dirtyFlag, setDirtyFlag] = React.useState(false);
    const [isItarAppFlag, setIsItarAppFlag] = useState(false);
    const [originalOrganizationTypeData, setOriginalOrganizationTypeData] = useState<OrganizationTypeMasterTable[]>([]);
    const [originalSupplierCategoryData, setOriginalSupplierCategoryData] = useState<SupplierCategoryMasterTable[]>([]);
    const [originalSupplierActivityData, setOriginalSupplierActivityData] = useState<SupplierActivityMasterTable[]>([]);
    const [originalFocalData, setOriginalFocalData] = useState<FocalMasterTable[]>([]);
    const [originalOrganizationData, setOriginalOrganizationData] = useState<OrganizationTableData[]>([]);
    const [shouldAutoCreateFocal, setShouldAutoCreateFocal] = useState(false);
    const handlePageChange = async (event: SelectChangeEvent<TableMaintenancePage>): Promise<void> => {
        var storageService = new StorageService();
        const dirtyResponse = await storageService.getUserConfirmationWithDirtyScreenCheck();
        if (!dirtyResponse) return;

        if (dirtyFlag) {
            if (selectedPage === AdminTableEnum.SUPPLIERACTIVITY) fetchSupplierActivity();
            else if (selectedPage === AdminTableEnum.SUPPLIERCATEGORY ) fetchSupplierCategory();
            else if (selectedPage === AdminTableEnum.ORGANIZATIONTYPE) fetchOrganizationType();
            else if (selectedPage === AdminTableEnum.ORGANIZATION && selectedOrgId !== "") fetchOrganization(selectedOrgId);
            else if (selectedPage === AdminTableEnum.FOCALMANAGEMENT && selectedOrgId !== "" && selectedOrganizationId !== "") fetchFocal(selectedOrgId, selectedOrganizationId);
        }

        setDirtyFlag(false);
        setSelectedPage(event.target.value as TableMaintenancePage);
    };
    const [organizationTypeData, setOrganizationTypeData] = useState<OrganizationTypeMasterTable[]>([]);
    const [organizationTypeDataState, setOrganizationTypeDataState] = React.useState<State>({});
    const [checklistTypeActiveItem, setChecklistTypeActiveItem] = useState<OrganizationTypeMasterTable | null>(null);
    const [organizationData, setOrganizationData] = useState<OrganizationTableData[]>([]);
    const [supplierActivityData, setSupplierActivityData] = useState<SupplierActivityMasterTable[]>([]);
    const [focalData, setFocalData] = useState<FocalMasterTable[]>([]);
    const [focalDataState, setFocalDataState] = React.useState<State>({});
    const [supplierCategoryData, setSupplierCategoryData] = useState<SupplierCategoryMasterTable[]>([]);
    const [supplierCategoryDataState, setSupplierCategoryDataState] = useState<State>({});
    const [organizationDataState, setOrganizationDataState] = useState<State>({});
    const [supplierActivityDataState, setSupplierActivityDataState] = useState<State>({});
    const [errorCodeMasterActiveItem, setErrorCodeMasterActiveItem] = useState<SupplierActivityMasterTable | null>(null);
    const [supplierCategoryActiveItem, setSupplierCategoryActiveItem] = useState<SupplierCategoryMasterTable | null>(null);
    const [focalActiveItem, setFocalActiveItem] = useState<FocalMasterTable | null>(null);
    const [organizationActiveItem, setOrganizationActiveItem] = useState<OrganizationTableData | null>(null);
    const [expandFocalId, setExpandFocalId] = useState<number | null>(null);

    // Organization Type handlers
    const CreateOrganizationType = () => {
        const newOrganizatonType: OrganizationTypeMasterTable = {
            ORGANIZATIONTYPEID: new Date().getTime(),
            ORGANIZATIONTYPE: "",
            newFlag: true,
            SORT_ORDER: organizationTypeData.length + 1,
            ISACTIVE: true
        };

        setOrganizationTypeData([newOrganizatonType, ...organizationTypeData]);
        setDirtyFlag(true);

    };
    const organizationTypeColumnPropsBuilder = (field) => {
        return {
            field: field,
            columnMenu: ColumnMenuBuilder,
            headerClassName: isColumnActive(field, organizationTypeDataState) ? "active kgrid-oss-checklistType-header" : "kgrid-oss-checklistType-header",
        };
    };
    const onOrganizationTypeDatastateChange = (event: GridDataStateChangeEvent) => {
        setOrganizationTypeDataState(event.dataState);
    };
    const organizationTypeItemChange = async (event: GridItemChangeEvent) => {
        let tempChickListType = [...organizationTypeData];
        const match = tempChickListType.findIndex((i) => i.ORGANIZATIONTYPEID === event.dataItem.ORGANIZATIONTYPEID);

        if (match !== -1 && event.field) {
            tempChickListType[match] = event.dataItem;
            setOrganizationTypeData(tempChickListType);
            setDirtyFlag(true);
        }
    };

    const saveOrganizationType = async () => {
        if (!dirtyFlag) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NODATA,
            }));
            return;
        }

        const current = [...organizationTypeData];
        const original = [...originalOrganizationTypeData];

        // Validation
        if (current.some((i) => !i.ORGANIZATIONTYPE || i.ORGANIZATIONTYPE.trim() === "")) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.PLEASEFILLDETAILS,
            }));
            return;
        }

        const uniqueCount = new Set(
            current.map((i) => i.ORGANIZATIONTYPE.trim().toLowerCase())
        ).size;

        if (uniqueCount !== current.length) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Organization Types must be unique.",
            }));
            return;
        }

        const items: MasterDataItem[] = [];

        current.forEach((row) => {
            const originalRow = original.find(o => o.ORGANIZATIONTYPEID === row.ORGANIZATIONTYPEID);

            if (!originalRow) {
                items.push({
                    Id: 0,
                    OperationType: AdminTableEnum.ADD,
                    Name: row.ORGANIZATIONTYPE.trim(),
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Description: "",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 1,
                    orgId: 1
                });
            }
            else if (
                originalRow.ORGANIZATIONTYPE !== row.ORGANIZATIONTYPE ||
                originalRow.ISACTIVE !== row.ISACTIVE ||
                originalRow.SORT_ORDER !== row.SORT_ORDER
            ) {
                items.push({
                    Id: row.ORGANIZATIONTYPEID,
                    OperationType: AdminTableEnum.UPDATE,
                    Name: row.ORGANIZATIONTYPE.trim(),
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Description: "",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }
        });

        if (items.length === 0) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NOCHANGES,
            }));
            return;
        }

        const payload: MasterDataPayload = {
            MasterDataType: AdminTableEnum.ORGANIZATIONTYPE,
            Items: items,
        };
        try {
            const response = await EasaListService.addMasterDataType(payload);
            if (response?.data === -1) {
                dispatch(showSnackbar({
                    snackbarOpen: true,
                    snackbarType: AdminTableEnum.ERROR,
                    snackbarMessage: "Error saving the Organization Type"
                }));
                return;
            }
            setDirtyFlag(false);
            fetchOrganizationType();

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Organization Type saved successfully.",
            }));
        } catch (error) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Error saving Organization Type.",
            }));
        }
    };
    const fetchOrganizationType = () => {
        let masterdataType = 0;
        EasaListService.getAdminMasterDetailsType(masterdataType)
            .then((response) => {
                let result: OrganizationTypeMasterTable[] = response?.data.map(x => ({
                    ORGANIZATIONTYPEID: x.ORGANIZATIONTYPEID,
                    ORGANIZATIONTYPE: x.ORGANIZATIONTYPE,
                    SORT_ORDER: x.SORT_ORDER,
                    ISACTIVE: x.ISACTIVE === "Y"
                }));

                setOrganizationTypeData([...result]);
                setOriginalOrganizationTypeData([...result]);
            })
            .catch((err) => console.error(err));
    };
    const organizationtypeDragStart = (dataItem: OrganizationTypeMasterTable) => {
        setChecklistTypeActiveItem(dataItem);
    };
    const organizationTypeReorder = (dataItem: OrganizationTypeMasterTable) => {
        if (checklistTypeActiveItem === dataItem) return;

        let reorderData = [...organizationTypeData];
        let prevIndex = reorderData.findIndex((p) => p === checklistTypeActiveItem);
        let nextIndex = reorderData.findIndex((p) => p === dataItem);
        reorderData.splice(prevIndex, 1);
        reorderData.splice(nextIndex, 0, checklistTypeActiveItem || reorderData[0]);
        let sorOrderIndex: number = 1;
        reorderData.forEach((row) => {
            row.SORT_ORDER = sorOrderIndex;
            sorOrderIndex++;
        });
        setOrganizationTypeData(reorderData);
        setDirtyFlag(true);
    };
    //organization handlers
    function organizationDragStart(dataItem: OrganizationTableData) {
        setOrganizationActiveItem(dataItem);
    }
    function organizationMasteReorder(dataItem: OrganizationTableData) {
        if (selectedPage === AdminTableEnum.ORGANIZATION) {
            if (organizationActiveItem === dataItem) return;
            let reorderData = [...organizationData];
            let prevIndex = reorderData.findIndex((p) => p === organizationActiveItem);
            let nextIndex = reorderData.findIndex((p) => p === dataItem);
            reorderData.splice(prevIndex, 1);
            reorderData.splice(nextIndex, 0, organizationActiveItem || reorderData[0]);
            let sorOrderIndex: number = 1;
            reorderData.forEach((row) => {
                row.SORT_ORDER = sorOrderIndex;
                sorOrderIndex++;
            });
            setOrganizationData(reorderData);
        }

        setDirtyFlag(true);
    }
    const organizationItemChange = (event: GridItemChangeEvent) => {

        const newData = organizationData.map(item => {

            if (item.ORGANIZATIONID === event.dataItem.ORGANIZATIONID) {

                return {
                    ...item,
                    [event.field as string]: event.value
                };
            }

            return item;
        });

        setOrganizationData(newData);
        setDirtyFlag(true);
    };
    const CreateOrganization = () => {
        const newOrganization: OrganizationTableData = {
            ORGANIZATIONID: new Date().getTime(),
            newFlag: true,
            SORT_ORDER: organizationData.length + 1,
            NOTES: "",
            ORGANIZATIONNAME: "",
            ORGANIZATIONDESCRIPTION: "",
            ISACTIVE: true,

        };
        setOrganizationData([newOrganization, ...organizationData]);
        setDirtyFlag(true);

    };
    const saveOrganization = async () => {

        if (!dirtyFlag) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NODATA,
            }));
            return;
        }

        const current = [...organizationData];
        const original = [...originalOrganizationData];

        // validation
        if (
            current.some(
                (i) =>
                    !i.ORGANIZATIONNAME ||
                    i.ORGANIZATIONNAME.trim() === ""
            )
        ) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.PLEASEFILLDETAILS,
            }));
            return;
        }

        // unique validation
        const uniqueCombinationCount = new Set(
            current.map(
                (i) =>
                    `${i.ORGANIZATIONNAME.trim().toLowerCase()}__${i.ORGANIZATIONDESCRIPTION?.trim().toLowerCase()}`
            )
        ).size;

        if (uniqueCombinationCount !== current.length) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage:
                    "Organization Name + Description must be unique.",
            }));
            return;
        }

        const items: MasterDataItem[] = [];

        current.forEach((row) => {
            const originalRow = original.find(o => o.ORGANIZATIONID === row.ORGANIZATIONID);
            if (!originalRow) {

                items.push({
                    Id: 0,
                    OperationType: AdminTableEnum.ADD,
                    Name: row.ORGANIZATIONNAME.trim(),
                    Description: row.ORGANIZATIONDESCRIPTION?.trim() || "",
                    Notes: row.NOTES?.trim() || "",
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: selectedOrgId as number
                });
            }

            // UPDATE
            else if (
                originalRow.ORGANIZATIONNAME !== row.ORGANIZATIONNAME ||
                originalRow.ORGANIZATIONDESCRIPTION !== row.ORGANIZATIONDESCRIPTION ||
                originalRow.NOTES !== row.NOTES ||
                originalRow.ISACTIVE !== row.ISACTIVE ||
                originalRow.SORT_ORDER !== row.SORT_ORDER
            ) {

                items.push({
                    Id: row.ORGANIZATIONID,
                    OperationType: AdminTableEnum.UPDATE,
                    Name: row.ORGANIZATIONNAME.trim(),
                    Description: row.ORGANIZATIONDESCRIPTION?.trim() || "",
                    Notes: row.NOTES?.trim() || "",
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }

        });

        if (items.length === 0) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NOCHANGES,
            }));
            return;
        }

        const payload: MasterDataPayload = {
            MasterDataType: AdminTableEnum.ORGANIZATION,
            Items: items,
        };

        try {
            const response = await EasaListService.addMasterDataType(payload);
            if (response?.data === -1) {
                dispatch(showSnackbar({
                    snackbarOpen: true,
                    snackbarType: AdminTableEnum.ERROR,
                    snackbarMessage: "Error saving the Organization"
                }));
                return;
            }

            setDirtyFlag(false);

            if (selectedOrgId !== "") {
                fetchOrganization(selectedOrgId);
            }

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Organization saved successfully.",
            }));

        } catch (error) {

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Error saving Organization.",
            }));
        }
    };
    const fetchOrganization = (orgTypeId: number) => {
        let masterdataType = 1;
        EasaListService.getAdminMasterDetailsOrgType(masterdataType, orgTypeId)
            .then((response) => {
                let result: OrganizationTableData[] = response?.data.map(org => ({
                    ORGANIZATIONID: org.ORGANIZATIONID,
                    ORGANIZATIONNAME: org.ORGANIZATIONNAME,
                    ORGANIZATIONDESCRIPTION: org.ORGANIZATIONDESCRIPTION,
                    NOTES: org.NOTES,
                    SORT_ORDER: org.SORT_ORDER,
                    ISACTIVE: org.ISACTIVE === "Y"
                }));
                setOrganizationData([...result]);
                setOriginalOrganizationData([...result]);
            })
            .catch((err) => console.error(err));
    };
    const onOrganizationDatastateChange = (event: GridDataStateChangeEvent) => {
        let temp = { filter: event.dataState.filter, sort: event.dataState.sort, take: undefined, skip: 0 }
        setOrganizationDataState(temp)
    };
    const OrganizationColumnPropsBuilder = (field) => {
        return {
            field: field,
            columnMenu: ColumnMenuBuilder,
            headerClassName: isColumnActive(field, supplierCategoryDataState) ? "active kgrid-oss-checklistType-header" : "kgrid-oss-checklistType-header",
        };
    };
    // Supplier Activity handlers
    const CreateSupplierActivity = () => {
        const newSupplierActivity: SupplierActivityMasterTable = {
            ACTIVITYID: new Date().getTime(),
            ACTIVITYDESCRIPTION: "",
            ACTIVITYCATEGORY: "",
            newFlag: true,
            SORT_ORDER: supplierActivityData.length + 1,
            ISACTIVE: true,
        };
        setSupplierActivityData([newSupplierActivity, ...supplierActivityData]);
        setDirtyFlag(true);
    };
    const supplierActivityColumnPropsBuilder = (field) => {
        return {
            field: field,
            columnMenu: ColumnMenuBuilder,
            headerClassName: isColumnActive(field, supplierActivityDataState) ? "active kgrid-oss-admin-table-errorCode1-header" : "kgrid-oss-admin-table-errorCode1-header",
        };
    };
    const onSupplierActivityDataStateChange = (event: GridDataStateChangeEvent) => {
        setSupplierActivityDataState(event.dataState);
    };
    const supplierActivityItemChange = async (event: GridItemChangeEvent) => {
        let tempErrorCodes = [...supplierActivityData];
        const match = tempErrorCodes.findIndex((i) => i.ACTIVITYID === event.dataItem.ACTIVITYID);

        if (match !== -1 && event.field) {
            tempErrorCodes[match] = event.dataItem;

            setSupplierActivityData(tempErrorCodes);
            setDirtyFlag(true);
        }
    };
    const onSaveSupplierActivity = async () => {
        if (!dirtyFlag) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NODATA,
            }));
            return;
        }

        const current = [...supplierActivityData];
        const original = [...originalSupplierActivityData];

        if (
            current.some(
                (i) =>
                    !i.ACTIVITYCATEGORY ||
                    i.ACTIVITYCATEGORY.trim() === ""
                // !i.ACTIVITYDESCRIPTION ||
                // i.ACTIVITYDESCRIPTION.trim() === ""
            )
        ) {
            dispatch(
                showSnackbar({
                    snackbarOpen: true,
                    snackbarType: AdminTableEnum.ERROR,
                    snackbarMessage: AdminTableEnum.PLEASEFILLDETAILS,
                })
            );
            return;
        }

        const uniqueCombinationCount = new Set(
            current.map(
                (i) =>
                    `${i.ACTIVITYCATEGORY.trim().toLowerCase()}__${i.ACTIVITYDESCRIPTION?.trim()?.toLowerCase()}`
            )
        ).size;

        if (uniqueCombinationCount !== current.length) {
            dispatch(
                showSnackbar({
                    snackbarOpen: true,
                    snackbarType: AdminTableEnum.ERROR,
                    snackbarMessage:
                        "Activity Category + Description  must be unique.",
                })
            );
            return;
        }

        const items: MasterDataItem[] = [];

        current.forEach((row) => {
            const originalRow = original.find(o => o.ACTIVITYID === row.ACTIVITYID);

            if (!originalRow) {
                items.push({
                    Id: 0,
                    OperationType: AdminTableEnum.ADD,
                    Name: row.ACTIVITYCATEGORY.trim(),
                    Description: row.ACTIVITYDESCRIPTION?.trim() || "",
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }
            else if (
                originalRow.ACTIVITYCATEGORY !== row.ACTIVITYCATEGORY ||
                originalRow.ACTIVITYDESCRIPTION !== row.ACTIVITYDESCRIPTION ||
                originalRow.ISACTIVE !== row.ISACTIVE ||
                originalRow.SORT_ORDER !== row.SORT_ORDER
            ) {
                items.push({
                    Id: row.ACTIVITYID,
                    OperationType: AdminTableEnum.UPDATE,
                    Name: row.ACTIVITYCATEGORY.trim(),
                    Description: row.ACTIVITYDESCRIPTION?.trim() || "",
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }
        });

        if (items.length === 0) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NOCHANGES,
            }));
            return;
        }

        const payload: MasterDataPayload = {
            MasterDataType: AdminTableEnum.SUPPLIERACTIVITY,
            Items: items,
        };

        try {
            const response = await EasaListService.addMasterDataType(payload);
            if (response?.data === -1) {
                dispatch(showSnackbar({
                    snackbarOpen: true,
                    snackbarType: AdminTableEnum.ERROR,
                    snackbarMessage: "Error saving the Supplier Activity"
                }));
                return;
            }
            setDirtyFlag(false);
            fetchSupplierActivity();

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Supplier Activity saved successfully.",
            }));
        } catch (error) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Error saving Supplier Activity.",
            }));
        }
    };
    const fetchSupplierActivity = () => {
        let masterdataType = 3;
        EasaListService.getAdminMasterDetailsType(masterdataType)
            .then((response) => {
                let result: SupplierActivityMasterTable[] = response?.data.map(x => ({
                    ACTIVITYID: x.ACTIVITYID,
                    ACTIVITYCATEGORY: x.ACTIVITYCATEGORY,
                    ACTIVITYDESCRIPTION: x.ACTIVITYDESCRIPTION,
                    ISACTIVE: x.ISACTIVE === "Y"
                }));

                setSupplierActivityData([...result]);
                setOriginalSupplierActivityData([...result]);
            })
            .catch((err) => console.error(err));
    };
    function supplierActivityMasterTableDragStart(dataItem: SupplierActivityMasterTable) {
        setErrorCodeMasterActiveItem(dataItem);
    }
    function supplierActivityMastereorder(dataItem: SupplierActivityMasterTable) {
        if (selectedPage === AdminTableEnum.SUPPLIERACTIVITY) {
            if (errorCodeMasterActiveItem === dataItem) return;
            let reorderData = [...supplierActivityData];
            let prevIndex = reorderData.findIndex((p) => p === errorCodeMasterActiveItem);
            let nextIndex = reorderData.findIndex((p) => p === dataItem);
            reorderData.splice(prevIndex, 1);
            reorderData.splice(nextIndex, 0, errorCodeMasterActiveItem || reorderData[0]);
            let sorOrderIndex: number = 1;
            reorderData.forEach((row) => {
                row.SORT_ORDER = sorOrderIndex;
                sorOrderIndex++;
            });
            setSupplierActivityData(reorderData);
        }
        setDirtyFlag(true);
    }

    //supplier category Handles
    function supplierCategoryMasterTableDragStart(dataItem: SupplierCategoryMasterTable) {
        setSupplierCategoryActiveItem(dataItem);
    }
    function supplierCategoryMasterReorder(dataItem: SupplierCategoryMasterTable) {
        if (selectedPage === AdminTableEnum.SUPPLIERCATEGORY) {
            if (supplierCategoryActiveItem === dataItem) return;
            let reorderData = [...supplierCategoryData];
            let prevIndex = reorderData.findIndex((p) => p === supplierCategoryActiveItem);
            let nextIndex = reorderData.findIndex((p) => p === dataItem);
            reorderData.splice(prevIndex, 1);
            reorderData.splice(nextIndex, 0, supplierCategoryActiveItem || reorderData[0]);
            let sorOrderIndex: number = 1;
            reorderData.forEach((row) => {
                row.SORT_ORDER = sorOrderIndex;
                sorOrderIndex++;
            });
            setSupplierCategoryData(reorderData);
        }

        setDirtyFlag(true);
    }
    const supplierCategoryTypeItemChange = async (event: GridItemChangeEvent) => {
        let tempSupplierCategoryType = [...supplierCategoryData];
        const match = tempSupplierCategoryType.findIndex((i) => i.CATEGORYID === event.dataItem.CATEGORYID);

        if (match !== -1 && event.field) {
            tempSupplierCategoryType[match] = event.dataItem;
            setSupplierCategoryData(tempSupplierCategoryType);
            setDirtyFlag(true);
        }
    };
    const CreateSupplierCategory = () => {
        const newSupplierCategory: SupplierCategoryMasterTable = {
            CATEGORYID: new Date().getTime(),
            CATEGORYDESCRIPTION: "",
            newFlag: true,
            SORT_ORDER: supplierActivityData.length + 1,
            ISACTIVE: true,

        };
        setSupplierCategoryData([newSupplierCategory, ...supplierCategoryData]);
        setDirtyFlag(true);

    };
    const saveSupplierCategory = async () => {
        if (!dirtyFlag) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NODATA,
            }));
            return;
        }

        const current = [...supplierCategoryData];
        const original = [...originalSupplierCategoryData];

        // Validation
        if (current.some((i) => !i.CATEGORYDESCRIPTION || i.CATEGORYDESCRIPTION.trim() === "")) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.PLEASEFILLDETAILS,
            }));
            return;
        }

        const uniqueCount = new Set(
            current.map((i) => i.CATEGORYDESCRIPTION.trim().toLowerCase())
        ).size;

        if (uniqueCount !== current.length) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Supplier Type must be unique.",
            }));
            return;
        }

        const items: MasterDataItem[] = [];

        current.forEach((row) => {
            const originalRow = original.find(o => o.CATEGORYID === row.CATEGORYID);

            if (!originalRow) {
                items.push({
                    Id: 0,
                    OperationType: AdminTableEnum.ADD,
                    Name: "",
                    Description: row.CATEGORYDESCRIPTION.trim(),
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }
            else if (
                originalRow.CATEGORYDESCRIPTION !== row.CATEGORYDESCRIPTION ||
                originalRow.ISACTIVE !== row.ISACTIVE ||
                originalRow.SORT_ORDER !== row.SORT_ORDER
            ) {
                items.push({
                    Id: row.CATEGORYID,
                    OperationType: AdminTableEnum.UPDATE,
                    Name: "",
                    Description: row.CATEGORYDESCRIPTION.trim(),
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }
        });

        if (items.length === 0) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NOCHANGES,
            }));
            return;
        }

        const payload: MasterDataPayload = {
            MasterDataType: AdminTableEnum.SUPPLIERCATEGORY,
            Items: items,
        };

        try {
            const response = await EasaListService.addMasterDataType(payload);
            if (response?.data === -1) {
                dispatch(showSnackbar({
                    snackbarOpen: true,
                    snackbarType: AdminTableEnum.ERROR,
                    snackbarMessage: "Error saving the Supplier Category"
                }));
                return;
            }
            setDirtyFlag(false);
            fetchSupplierCategory();

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Supplier Category saved successfully.",
            }));
        } catch (error) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Error saving Supplier Category.",
            }));
        }
    };
    const fetchSupplierCategory = () => {
        let masterdataType = 2;
        EasaListService.getAdminMasterDetailsType(masterdataType)
            .then((response) => {
                let result: SupplierCategoryMasterTable[] = response?.data.map(category => ({
                    CATEGORYID: category.CATEGORYID,
                    CATEGORYDESCRIPTION: category.CATEGORYDESCRIPTION,
                    ISACTIVE: category.ISACTIVE === "Y",
                }));
                setSupplierCategoryData([...result]);
                setOriginalSupplierCategoryData([...result]);
            })
            .catch((err) => console.error(err));
    };
    const onSupplierCategoryDatastateChange = (event: GridDataStateChangeEvent) => {
        setSupplierCategoryDataState(event.dataState)
    };
    const supplierCategoryColumnPropsBuilder = (field) => {
        return {
            field: field,
            columnMenu: ColumnMenuBuilder,
            headerClassName: isColumnActive(field, supplierCategoryDataState) ? "active kgrid-oss-checklistType-header" : "kgrid-oss-checklistType-header",
        };
    };
    // Focal Handlers
    const CreateFocal = () => {
        const newFocal: FocalMasterTable = {
            ID: new Date().getTime(),
            NAME: "",
            PHONE: "",
            ADDRESS: "",
            EMAIL: "",
            DEPARTMENT: "",
            TITLE: "",
            newFlag: true,
            SORT_ORDER: focalData.length + 1,
            ISACTIVE: true,
        };
        setFocalData([newFocal, ...focalData]);
    };
    const focalColumnPropsBuilder = (field) => {
        return {
            field: field,
            columnMenu: ColumnMenuBuilder,
            headerClassName: isColumnActive(field, focalDataState) ? "active kgrid-oss-admin-table-errorCode1-header" : "kgrid-oss-admin-table-errorCode1-header",
        };
    };
    const onFocalDataStateChange = (event: GridDataStateChangeEvent) => {
        setFocalDataState(event.dataState);
    };
    const focalItemChange = async (event: GridItemChangeEvent) => {
        let tempErrorCodes = [...focalData];
        const match = tempErrorCodes.findIndex((i) => i.ID === event.dataItem.ID);

        if (match !== -1 && event.field) {
            tempErrorCodes[match] = event.dataItem;

            setFocalData(tempErrorCodes);
            setDirtyFlag(true);
        }
    };
    const onSaveFocal = async () => {
        if (!dirtyFlag) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NODATA,
            }));
            return;
        }

        const current = [...focalData];
        const original = [...originalFocalData];
        const items: MasterDataItem[] = [];

        current.forEach((row) => {
            const originalRow = original.find(o => o.ID === row.ID);

            if (!originalRow) {
                items.push({
                    Id: 0,
                    OperationType: AdminTableEnum.ADD,
                    Name: row.NAME?.trim(),
                    Description: "",
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: row.ADDRESS ?? "",
                    Department: "",
                    Phone: row.PHONE ?? 0,
                    Email: "",
                    Title: "",
                    orgTypeId: 0
                });
            }
            else if (
                originalRow.NAME !== row.NAME ||
                originalRow.PHONE !== row.PHONE ||
                originalRow.ADDRESS !== row.ADDRESS ||
                originalRow.EMAIL !== row.EMAIL ||
                originalRow.DEPARTMENT !== row.DEPARTMENT ||
                originalRow.TITLE !== row.TITLE ||
                originalRow.ISACTIVE !== row.ISACTIVE ||
                originalRow.SORT_ORDER !== row.SORT_ORDER
            ) {
                items.push({
                    Id: row.ID,
                    OperationType: AdminTableEnum.UPDATE,
                    Name: row.NAME,
                    Description: "",
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: row.ADDRESS ?? "",
                    Department: row.DEPARTMENT ?? "",
                    Phone: row.PHONE ?? "",
                    Email: row.EMAIL ?? "",
                    Title: row.TITLE ?? "",
                    orgTypeId: 0
                });
            }
        });

        if (items.length === 0) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: AdminTableEnum.NOCHANGES,
            }));
            return;
        }

        const payload: MasterDataPayload = {
            MasterDataType: AdminTableEnum.FOCALMANAGEMENT,
            Items: items,
        };

        try {
            await EasaListService.addMasterDataType(payload);

            setDirtyFlag(false);
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Focal saved successfully.",
            }));
        } catch (error) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: AdminTableEnum.ERROR,
                snackbarMessage: "Error saving Focal.",
            }));
        }
    };
    const handleCreateFocalFromOrg = async (orgId: number, orgTypeId: number) => {
        setSelectedOrgId(orgTypeId);
        setSelectedOrganizationId(orgId);
        setSelectedPage(AdminTableEnum.FOCALMANAGEMENT);
        setFocalData([]);
        setOriginalFocalData([]);
        setFocalDataState({})

        try {
            const response = await EasaListService.getAdminMasterDetailsTypeFocals(4, orgTypeId, orgId);

            let result: FocalMasterTable[] = response?.data.map(x => ({
                ID: x.ID,
                NAME: x.NAME,
                PHONE: x.PHONE,
                ADDRESS: x.ADDRESS,
                EMAIL: x.EMAIL,
                DEPARTMENT: x.DEPARTMENT,
                TITLE: x.TITLE,
                ISACTIVE: x.ISACTIVE === "Y",
            }));

            setFocalData([...result]);
            setOriginalFocalData([...result]);
            setShouldAutoCreateFocal(true);

        } catch (err) {
            console.error(err);
        }
    };
    const fetchFocal = async (orgName: number, orgTypeId: number) => {
        let masterdataType = 4;
        EasaListService.getAdminMasterDetailsTypeFocals(masterdataType, orgName, orgTypeId)
            .then((response) => {
                let result: FocalMasterTable[] = response?.data.map(x => ({
                    ID: x.ID,
                    NAME: x.NAME,
                    PHONE: x.PHONE,
                    ADDRESS: x.ADDRESS,
                    EMAIL: x.EMAIL,
                    DEPARTMENT: x.DEPARTMENT,
                    TITLE: x.TITLE,
                    ISACTIVE: x.ISACTIVE === "Y",
                }));

                setFocalData([...result]);
                setOriginalFocalData([...result]);
            })
            .catch((err) => console.error(err));
    };
    function focalMasterTableDragStart(dataItem: FocalMasterTable) {
        setFocalActiveItem(dataItem);
    }
    function focalMastereorder(dataItem: FocalMasterTable) {
        if (selectedPage === AdminTableEnum.FOCALMANAGEMENT) {
            if (focalActiveItem === dataItem) return;
            let reorderData = [...focalData];
            let prevIndex = reorderData.findIndex((p) => p === focalActiveItem);
            let nextIndex = reorderData.findIndex((p) => p === dataItem);
            reorderData.splice(prevIndex, 1);
            reorderData.splice(nextIndex, 0, focalActiveItem || reorderData[0]);
            let sorOrderIndex: number = 1;
            reorderData.forEach((row) => {
                row.SORT_ORDER = sorOrderIndex;
                sorOrderIndex++;
            });
            setFocalData(reorderData);
        }
        setDirtyFlag(true);
    }
    //sorting functionality
    const handleSortByChange = (key: keyof SortByData, value: AdminTableEnum.CUSTOM | AdminTableEnum.ASC | AdminTableEnum.DESC, setScreenDirty: boolean = true) => {
        if (key === 'organization') {
            let ascChecklistData: OrganizationTableData[] = [...organizationData];

            if (value === AdminTableEnum.ASC || value === AdminTableEnum.DESC) {
                ascChecklistData = _.orderBy(ascChecklistData, ["ORGANIZATIONNAME"], [value]);

                let i = 1;
                ascChecklistData = ascChecklistData.map(x => ({ ...x, Sorting: i++ }));
                setOrganizationData(ascChecklistData);
            }
        }

        if (key === 'organizationType') {
            let ascChecklistData: OrganizationTypeMasterTable[] = [...organizationTypeData];

            if (value === AdminTableEnum.ASC || value === AdminTableEnum.DESC) {
                ascChecklistData = _.orderBy(ascChecklistData, ["ORGANIZATIONTYPE"], [value]);

                let i = 1;
                ascChecklistData = ascChecklistData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setOrganizationTypeData(ascChecklistData);
            }
        }

        if (key === 'supplierCategory') {
            let ascChecklistData: SupplierCategoryMasterTable[] = [...supplierCategoryData];

            if (value === AdminTableEnum.ASC || value === AdminTableEnum.DESC) {
                ascChecklistData = _.orderBy(ascChecklistData, ["CATEGORYDESCRIPTION"], [value]);

                let i = 1;
                ascChecklistData = ascChecklistData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setSupplierCategoryData(ascChecklistData);
            }
        }

        if (key === 'supplierActivity') {
            let ascErrorCodeData: SupplierActivityMasterTable[] = [...supplierActivityData];

            if (value === AdminTableEnum.ASC || value === AdminTableEnum.DESC) {
                ascErrorCodeData = _.orderBy(ascErrorCodeData, ["ACTIVITYCATEGORY"], [value]);

                let i = 1;
                ascErrorCodeData = ascErrorCodeData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setSupplierActivityData(ascErrorCodeData);
            }
        }
        if (key === 'focal') {
            let ascErrorCodeData: FocalMasterTable[] = [...focalData];

            if (value === AdminTableEnum.ASC || value === AdminTableEnum.DESC) {
                ascErrorCodeData = _.orderBy(ascErrorCodeData, ["NAME"], [value]);

                let i = 1;
                ascErrorCodeData = ascErrorCodeData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setFocalData(ascErrorCodeData);
            }
        }

        setSortBy({ ...sortBy, [key]: value });
        if (setScreenDirty) {
            setDirtyFlag(true);
        }
    }

    //Handle fetching Register Types Asynchronously
    const fetchMasterDataTypes = async () => {
        const result = await EasaListService.getAdminMasterData();
        const data = result?.data ?? [];
        setMasterDataOptions(data);
    };
    const handleOrg = async (event) => {
        const storageService = new StorageService();
        const dirtyResponse = await storageService.getUserConfirmationWithDirtyScreenCheck();
        if (!dirtyResponse) return;
        const orgTypeId = event.target.value;
        setSelectedOrgId(orgTypeId);
        setSelectedOrganizationId("");

        try {
            const response = await EasaListService.getAdminMasterDetailsOrgType(1, orgTypeId);

            let result: OrganizationTableData[] = response?.data.map(org => ({
                ORGANIZATIONID: org.ORGANIZATIONID,
                ORGANIZATIONNAME: org.ORGANIZATIONNAME,
                ORGANIZATIONDESCRIPTION: org.ORGANIZATIONDESCRIPTION,
                NOTES: org.NOTES,
                SORT_ORDER: org.SORT_ORDER,
                ISACTIVE: org.ISACTIVE === "Y"
            }));

            const finalResult = [...result];

            setOrganizationData(finalResult);
            setOriginalOrganizationData(finalResult);

            if (finalResult.length > 0) {
                setSelectedOrganizationId(finalResult[0].ORGANIZATIONID);
            } else {
                setSelectedOrganizationId("");
                setFocalData([]);
                setOriginalFocalData([]);
            }
            setDirtyFlag(false);
        } catch (err) {
            console.error(err);
        }
    }
    const handleOrganization = async (event) => {
        const storageService = new StorageService();
        const dirtyResponse = await storageService.getUserConfirmationWithDirtyScreenCheck();
        if (!dirtyResponse) return;

        const orgId = event.target.value;
        setSelectedOrganizationId(orgId);
        fetchFocal(selectedOrgId as number, orgId);
        setDirtyFlag(false);
    };
    useEffect(() => {
        if (selectedOrgId !== "") {
            fetchOrganization(selectedOrgId);
        }
    }, [selectedOrgId])
    useEffect(() => {
        if (shouldAutoCreateFocal) {
            CreateFocal();
            setShouldAutoCreateFocal(false);
        }
    }, [focalData, shouldAutoCreateFocal]);
    useEffect(() => {
        var storageService = new StorageService();
        let isItarApp = storageService.getIsItarApp();
        setIsItarAppFlag(isItarApp == "Y" ? true : false);
        fetchOrganizationType();
        fetchSupplierCategory();
        fetchSupplierActivity();
    }, []);
    useEffect(() => {
        if (organizationTypeData.length > 0 && selectedOrgId === "") {
            setSelectedOrgId(organizationTypeData[0]?.ORGANIZATIONTYPEID);
        }
    }, [organizationTypeData, selectedOrgId]);
    useEffect(() => {
        if (organizationData.length > 0 && selectedOrganizationId === "") {
            setSelectedOrganizationId(organizationData[0].ORGANIZATIONID);
        }
    }, [organizationData, selectedOrganizationId]);
    useEffect(() => {
        if (selectedOrgId !== "" && selectedOrganizationId !== "") {
            fetchFocal(selectedOrgId, selectedOrganizationId);
        }
    }, [selectedOrgId, selectedOrganizationId]);

    useEffect(() => {
        const storageService = new StorageService();
        storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, dirtyFlag);

        return () => {
            storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, false);
        };
    }, [dirtyFlag]);
    useEffect(() => {
        fetchMasterDataTypes();
    }, []);
    return (
        <div className="EASA-Admin-table-maintenance">
            <div className="EASA-Admin-table-maintenance-topbar">
                <div>Master Data</div>
                <Select id="admin-table-page-selector" style={{ maxWidth: isItarAppFlag ? 280 : 210, minWidth: isItarAppFlag ? 280 : 210 }} value={selectedPage} onChange={handlePageChange} size="medium">
                    {masterDataOptions.map(({ MasterDataId, MasterData }) => (
                        <MenuItem
                            key={MasterDataId}
                            value={MasterData}
                            className="text-normal"
                        >
                            {MasterData}
                        </MenuItem>
                    ))}
                </Select>
                {(selectedPage === AdminTableEnum.ORGANIZATION || selectedPage === AdminTableEnum.FOCALMANAGEMENT) && (
                    <div style={{ marginLeft: 16, display: "flex", gap: 8, justifyContent: "flex-start", alignItems: "center", fontSize: 14 }}>
                        Organization Type
                        <Select
                            id="admin-table-page-orgtype-selector"
                            style={{ maxWidth: 280, minWidth: 250 }}
                            value={selectedOrgId}
                            onChange={handleOrg}
                            size="medium"
                            MenuProps={{
                                PaperProps: {
                                    sx: {
                                        height: 170,
                                        overflowY: "auto"
                                    }
                                }
                            }}
                        >
                            {(organizationTypeData).map(item => (
                                <MenuItem
                                    key={item.ORGANIZATIONTYPEID}
                                    value={item.ORGANIZATIONTYPEID}
                                    className="text-normal"
                                >
                                    {item.ORGANIZATIONTYPE}
                                </MenuItem>
                            ))}
                        </Select>
                    </div>
                )}
                {(selectedPage === AdminTableEnum.FOCALMANAGEMENT) && (
                    <div style={{ marginLeft: 16, display: "flex", gap: 8, justifyContent: "flex-start", alignItems: "center", fontSize: 14 }}>
                        Organization
                        <Select
                            id="admin-table-page-org-selector"
                            value={selectedOrganizationId}
                            onChange={handleOrganization}
                            size="medium"
                            sx={{ minWidth: 250, maxWidth: 250 }}
                            MenuProps={{
                                PaperProps: {
                                    sx: {
                                        minHeight: 30,
                                        maxHeight: 170,
                                        maxWidth: 250,
                                        width: 250,
                                    }
                                }
                            }}
                        >
                            {organizationData.map(item => (
                                <MenuItem
                                    key={item.ORGANIZATIONID}
                                    value={item.ORGANIZATIONID}
                                    sx={{
                                        maxWidth: 250,
                                        whiteSpace: "nowrap",
                                        overflow: "hidden",
                                        textOverflow: "ellipsis",
                                        display: "block"
                                    }}
                                >
                                    {item.ORGANIZATIONNAME}
                                </MenuItem>
                            ))}
                        </Select>
                    </div>
                )}
            </div>

            <div className="EASA-Admin-table-maintenance-section">
                {selectedPage === AdminTableEnum.SUPPLIERCATEGORY && (
                    <>
                        <SupplierCategoryTable
                            key="kgrid-oss-admin-table-checklistType-comp"
                            columnPropsBuilder={supplierCategoryColumnPropsBuilder}
                            KEY={SUPPLIER_CATEGORY_DATA_ITEM_KEY}
                            supplierCategoryData={supplierCategoryData}
                            dataState={supplierCategoryDataState}
                            dataStateChange={onSupplierCategoryDatastateChange}
                            itemChange={supplierCategoryTypeItemChange}
                            createSupplierCategory={CreateSupplierCategory}
                            saveSupplierCategory={saveSupplierCategory}
                            dragStart={supplierCategoryMasterTableDragStart}
                            reorder={supplierCategoryMasterReorder}
                            sortBy={sortBy.supplierCategory}
                            handleSortByChange={handleSortByChange}
                        />
                    </>
                )}

                {
                    selectedPage === AdminTableEnum.ORGANIZATION && (
                        <OrganizationTable
                            key="kgrid-oss-admin-table-errorCode-comp-1"
                            KEY={ORGANIZATION_DATA_ITEM_KEY}
                            columnPropsBuilder={OrganizationColumnPropsBuilder}
                            organizationData={organizationData}
                            dataState={organizationDataState}
                            dataStateChange={onOrganizationDatastateChange}
                            itemChange={organizationItemChange}
                            createOrganization={CreateOrganization}
                            onCreateFocal={handleCreateFocalFromOrg}
                            saveOrganization={saveOrganization}
                            dragStart={organizationDragStart}
                            reorder={organizationMasteReorder}
                            selectedOrgId={selectedOrgId as number}
                            sortBy={sortBy.supplierActivity}
                            handleSortByChange={handleSortByChange}
                        />
                    )
                }

                {selectedPage === AdminTableEnum.ORGANIZATIONTYPE && (
                    <OrganizationTypeTable
                        key="kgrid-oss-admin-table-checklistType-comp"
                        KEY={ORGANIZATION_TYPE_DATA_ITEM_KEY}
                        columnPropsBuilder={organizationTypeColumnPropsBuilder}
                        organizationTypeData={organizationTypeData}
                        dataState={organizationTypeDataState}
                        dataStateChange={onOrganizationTypeDatastateChange}
                        itemChange={organizationTypeItemChange}
                        createOrganizationType={CreateOrganizationType}
                        saveOrganizationType={saveOrganizationType}
                        dragStart={organizationtypeDragStart}
                        reorder={organizationTypeReorder}
                        sortBy={sortBy.organizationType}
                        handleSortByChange={handleSortByChange}
                    />
                )}

                {selectedPage === AdminTableEnum.SUPPLIERACTIVITY && (
                    <SupplierActivityTable
                        key="kgrid-oss-admin-table-errorCode-comp-1"
                        KEY={SUPPLIER_ACTIVITY_DATA_ITEM_KEY}
                        columnPropsBuilder={supplierActivityColumnPropsBuilder}
                        supplierActivityData={supplierActivityData}
                        dataState={supplierActivityDataState}
                        dataStateChange={onSupplierActivityDataStateChange}
                        itemChange={supplierActivityItemChange}
                        createSupplierActivity={CreateSupplierActivity}
                        saveSupplierActivity={onSaveSupplierActivity}
                        dragStart={supplierActivityMasterTableDragStart}
                        reorder={supplierActivityMastereorder}
                        sortBy={sortBy.supplierActivity}
                        handleSortByChange={handleSortByChange}
                    />
                )}
                {selectedPage === AdminTableEnum.FOCALMANAGEMENT && (
                    <FocalTable
                        key="kgrid-oss-admin-table-errorCode-comp-1"
                        KEY={FOCAL_DATA_ITEM_KEY}
                        columnPropsBuilder={focalColumnPropsBuilder}
                        focalData={focalData}
                        expandFocalId={expandFocalId}
                        dataState={focalDataState}
                        dataStateChange={onFocalDataStateChange}
                        itemChange={focalItemChange}
                        createFocal={CreateFocal}
                        saveFocal={onSaveFocal}
                        selectedOrgId={selectedOrgId as number}
                        selectedOrganizationId={selectedOrganizationId as number}
                        fetchFocal={fetchFocal}
                        dragStart={focalMasterTableDragStart}
                        reorder={focalMastereorder}
                        sortBy={sortBy.focal}
                        handleSortByChange={handleSortByChange}
                        setDirtyFlag={setDirtyFlag}
                    />
                )}
            </div>
        </div>
    );
};

export default TableMaintenance;
