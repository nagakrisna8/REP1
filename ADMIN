const objectsEqual = (o1: any, o2: any) => (typeof o1 === "object" && Object.keys(o1).length > 0 ? Object.keys(o1).length === Object.keys(o2).length && Object.keys(o1).every((p) => objectsEqual(o1[p], o2[p])) : o1 === o2);

const arraysEqual = (a1: Array<any>, a2: Array<any>) => a1.length === a2.length && a1.every((o, idx) => objectsEqual(o, a2[idx]));
