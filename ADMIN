import "./AdminTable.scss";
import {
    MenuItem, Select,
    SelectChangeEvent
} from "@mui/material";
import React, { useEffect, useState } from "react";
import {
    OrganizationTypeMasterTable,
    SupplierActivityMasterTable, GetAdminSortByResponse,
    SortByData,
    SupplierCategoryMasterTable, OrganizationTableData,
    MasterDataItem,
    FocalMasterTable,
    AdminTableEnum
} from "./AdminModal";

import EasaListService from "../EasaRegisterListService";
import { useDispatch } from "react-redux";
import { State, getter } from "@progress/kendo-data-query";
import {
    GridColumnMenuFilter, GridColumnMenuSort,
    GridDataStateChangeEvent, GridItemChangeEvent,
    isColumnMenuFilterActive,
    isColumnMenuSortActive
} from "@progress/kendo-react-grid";
import * as _ from "lodash";
import EnvDetail from "../../../../../utils/EnvDetail";
