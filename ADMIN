import "./AdminTable.scss";
import { MenuItem, Select, SelectChangeEvent } from "@mui/material";
import React, { useEffect, useState } from "react";
import {
    OrganizationTypeMasterTable,
    SupplierActivityMasterTable,
    GetAdminSortByResponse,
    SortByData,
    SupplierCategoryMasterTable,
    OrganizationTableData,
    MasterDataItem
} from "./AdminModal";

import EasaListService from "../EasaRegisterListService";
import { useDispatch } from "react-redux";
import { State } from "@progress/kendo-data-query";
import {
    GridColumnMenuFilter,
    GridColumnMenuSort,
    GridDataStateChangeEvent,
    GridItemChangeEvent,
    isColumnMenuFilterActive,
    isColumnMenuSortActive
} from "@progress/kendo-react-grid";

import orderBy from "lodash/orderBy";

import EnvDetail from "../../../../../utils/EnvDetail";
import { showSnackbar } from "../../../../core/snackbar/CustomSnackBarSlice";
import StorageService from "../../../../../utils/StorageService";

import OrganizationTypeTable from "./OrganizationType/OrganizationTypeTable";
import SupplierActivityTable from "./SupplierActivity/SupplierActivityTable";
import SupplierCategoryTable from "./SupplierCategory/SupplierCategoryTable";
import OrganizationTable from "./Organization/OrganizationTable.Component";

const ORGANIZATION_TYPE_DATA_ITEM_KEY = "ORGANIZATIONTYPEID";
const SUPPLIER_ACTIVITY_DATA_ITEM_KEY = "ID";
const ORGANIZATION_DATA_ITEM_KEY = "ORGANIZATIONID";
const SUPPLIER_CATEGORY_DATA_ITEM_KEY = "ID";

const ColumnMenuBuilder = (props: any) => {
    return (
        <div>
            <GridColumnMenuSort {...props} />
            <GridColumnMenuFilter {...props} expanded={true} />
        </div>
    );
};

interface MasterDataPayload {
    MasterDataType: string;
    Items: MasterDataItem[];
}

const Options = [
    "Organization Type",
    "Organization",
    "Supplier Category",
    "Supplier Activity Authorized"
];

const isColumnActive = (field: string, dataState: State) => {
    return (
        isColumnMenuFilterActive(field, dataState.filter) ||
        isColumnMenuSortActive(field, dataState.sort)
    );
};

type TableMaintenancePage =
    | "Organization Type"
    | "Organization"
    | "Supplier Category"
    | "Supplier Activity Authorized";

const TableMaintenance: React.FC = () => {

    const dispatch = useDispatch();

    const [sortBy, setSortBy] = useState<SortByData>({
        organization: "custom",
        organizationType: "custom",
        supplierCategory: "custom",
        supplierActivity: "custom"
    });

    const [initialAdminSortBy] = useState<GetAdminSortByResponse>({
        BusinessUnitId: 0,
        DisciplineId: 0,
        BuSystemMappingId: 0,
        OrganizationTypeSortBy: "custom",
        OrganizationSortBy: "custom",
        SupplierCategorySortBy: "custom",
        SupplierActivitySortBy: "custom"
    });

    const [selectedOrgId, setSelectedOrgId] = useState<number>(1);
    const [masterDataOptions, setMasterDataOptions] = useState<any[]>([]);
    const [selectedPage, setSelectedPage] =
        useState<TableMaintenancePage>("Organization Type");

    const [dirtyFlag, setDirtyFlag] = useState(false);
    const [isItarAppFlag, setIsItarAppFlag] = useState(false);

    const [originalOrganizationTypeData, setOriginalOrganizationTypeData] =
        useState<OrganizationTypeMasterTable[]>([]);

    const [originalSupplierCategoryData, setOriginalSupplierCategoryData] =
        useState<SupplierCategoryMasterTable[]>([]);

    const [originalSupplierActivityData, setOriginalSupplierActivityData] =
        useState<SupplierActivityMasterTable[]>([]);

    const [originalOrganizationData, setOriginalOrganizationData] =
        useState<OrganizationTableData[]>([]);

    const [organizationTypeData, setOrganizationTypeData] =
        useState<OrganizationTypeMasterTable[]>([]);

    const [organizationTypeDataState, setOrganizationTypeDataState] =
        useState<State>({});

    const [checklistTypeActiveItem, setChecklistTypeActiveItem] =
        useState<OrganizationTypeMasterTable | null>(null);

    const [organizationData, setOrganizationData] =
        useState<OrganizationTableData[]>([]);

    const [supplierActivityData, setSupplierActivityData] =
        useState<SupplierActivityMasterTable[]>([]);

    const [supplierCategoryData, setSupplierCategoryData] =
        useState<SupplierCategoryMasterTable[]>([]);

    const [supplierCategoryDataState, setSupplierCategoryDataState] =
        useState<State>({});

    const [organizationDataState, setOrganizationDataState] =
        useState<State>({});

    const [supplierActivityDataState, setSupplierActivityDataState] =
        useState<State>({});

    const [errorCodeMasterActiveItem, setErrorCodeMasterActiveItem] =
        useState<SupplierActivityMasterTable | null>(null);

    const [supplierCategoryActiveItem, setSupplierCategoryActiveItem] =
        useState<SupplierCategoryMasterTable | null>(null);

    const [organizationActiveItem, setOrganizationActiveItem] =
        useState<OrganizationTableData | null>(null);

    const handlePageChange = async (
        event: SelectChangeEvent<TableMaintenancePage>
    ): Promise<void> => {

        const storageService = new StorageService();
        const dirtyResponse =
            await storageService.getUserConfirmationWithDirtyScreenCheck();

        if (!dirtyResponse) return;

        if (dirtyFlag) {
            if (selectedPage === "Supplier Activity Authorized")
                fetchSupplierActivity();
            else if (selectedPage === "Supplier Category")
                fetchSupplierCategory();
            else if (selectedPage === "Organization Type")
                fetchOrganizationType();
            else if (selectedPage === "Organization")
                fetchOrganization(selectedOrgId);
        }

        setDirtyFlag(false);
        setSelectedPage(event.target.value as TableMaintenancePage);
    };

    const CreateOrganizationType = () => {

        const newOrganizatonType: OrganizationTypeMasterTable = {
            ORGANIZATIONTYPEID: new Date().getTime(),
            ORGANIZATIONTYPE: "",
            newFlag: true,
            SORT_ORDER: organizationTypeData.length + 1,
            ISACTIVE: true
        };

        setOrganizationTypeData([newOrganizatonType, ...organizationTypeData]);
        setDirtyFlag(true);
    };

    const organizationTypeColumnPropsBuilder = (field: string) => ({
        field,
        columnMenu: ColumnMenuBuilder,
        headerClassName: isColumnActive(field, organizationTypeDataState)
            ? "active kgrid-oss-checklistType-header"
            : "kgrid-oss-checklistType-header"
    });

    const onOrganizationTypeDatastateChange = (
        event: GridDataStateChangeEvent
    ) => {
        setOrganizationTypeDataState(event.dataState);
    };

    const organizationTypeItemChange = (event: GridItemChangeEvent) => {

        const temp = [...organizationTypeData];
        const index = temp.findIndex(
            i => i.ORGANIZATIONTYPEID === event.dataItem.ORGANIZATIONTYPEID
        );

        if (index !== -1 && event.field) {
            temp[index] = event.dataItem;
            setOrganizationTypeData(temp);
            setDirtyFlag(true);
        }
    };

    const fetchOrganizationType = () => {

        EasaListService.getAdminMasterDetailsType(0)
            .then((response) => {

                const result: OrganizationTypeMasterTable[] =
                    response?.data.map((x: any) => ({
                        ORGANIZATIONTYPEID: x.ORGANIZATIONTYPEID,
                        ORGANIZATIONTYPE: x.ORGANIZATIONTYPE,
                        SORT_ORDER: x.SORT_ORDER,
                        ISACTIVE: x.ISACTIVE === "Y"
                    }));

                setOrganizationTypeData([...result].reverse());
                setOriginalOrganizationTypeData([...result].reverse());
            })
            .catch(console.error);
    };

    const handleSortByChange = (
        key: keyof SortByData,
        value: "custom" | "asc" | "desc",
        setScreenDirty: boolean = true
    ) => {

        if (key === "organizationType") {

            let data = [...organizationTypeData];

            if (value === "asc" || value === "desc") {

                data = orderBy(data, ["ORGANIZATIONTYPE"], [value]);

                let i = 1;
                data = data.map(x => ({ ...x, SORT_ORDER: i++ }));

                setOrganizationTypeData(data);
            }
        }

        if (key === "supplierCategory") {

            let data = [...supplierCategoryData];

            if (value === "asc" || value === "desc") {

                data = orderBy(data, ["CATEGORYDESCRIPTION"], [value]);

                let i = 1;
                data = data.map(x => ({ ...x, SORT_ORDER: i++ }));

                setSupplierCategoryData(data);
            }
        }

        if (key === "supplierActivity") {

            let data = [...supplierActivityData];

            if (value === "asc" || value === "desc") {

                data = orderBy(data, ["ACTIVITYCATEGORY"], [value]);

                let i = 1;
                data = data.map(x => ({ ...x, SORT_ORDER: i++ }));

                setSupplierActivityData(data);
            }
        }

        setSortBy({ ...sortBy, [key]: value });

        if (setScreenDirty) setDirtyFlag(true);
    };

    const fetchMasterDataTypes = async () => {

        const result = await EasaListService.getAdminMasterData();
        const data = result?.data ?? [];

        setMasterDataOptions(data);
    };

    const handleOrg = (event: any) => {

        const orgTypeId = event.target.value;

        setSelectedOrgId(orgTypeId);

        fetchOrganization(orgTypeId);
    };

    useEffect(() => {

        const storageService = new StorageService();

        const isItarApp = storageService.getIsItarApp();

        setIsItarAppFlag(isItarApp === "Y");

        fetchOrganizationType();
        fetchSupplierCategory();
        fetchSupplierActivity();

    }, []);

    useEffect(() => {
        fetchMasterDataTypes();
    }, []);

    return (
        <div className="EASA-Admin-table-maintenance">

            <div className="EASA-Admin-table-maintenance-topbar">

                <div>Master Data</div>

                <Select
                    id="admin-table-page-selector"
                    style={{
                        maxWidth: isItarAppFlag ? 280 : 210,
                        minWidth: isItarAppFlag ? 280 : 210
                    }}
                    value={selectedPage}
                    onChange={handlePageChange}
                >

                    {Options.map(item => (
                        <MenuItem key={item} value={item}>
                            {item}
                        </MenuItem>
                    ))}

                </Select>
            </div>

            <div className="EASA-Admin-table-maintenance-section">

                {selectedPage === "Supplier Category" && (
                    <SupplierCategoryTable
                        KEY={SUPPLIER_CATEGORY_DATA_ITEM_KEY}
                        columnPropsBuilder={supplierCategoryColumnPropsBuilder}
                        supplierCategoryData={supplierCategoryData}
                        dataState={supplierCategoryDataState}
                        dataStateChange={onSupplierCategoryDatastateChange}
                        itemChange={supplierCategoryTypeItemChange}
                        createSupplierCategory={CreateSupplierCategory}
                        saveSupplierCategory={saveSupplierCategory}
                        dragStart={supplierCategoryMasterTableDragStart}
                        reorder={supplierCategoryMasterReorder}
                        sortBy={sortBy.supplierCategory}
                        handleSortByChange={handleSortByChange}
                    />
                )}

                {selectedPage === "Organization Type" && (
                    <OrganizationTypeTable
                        KEY={ORGANIZATION_TYPE_DATA_ITEM_KEY}
                        columnPropsBuilder={organizationTypeColumnPropsBuilder}
                        organizationTypeData={organizationTypeData}
                        dataState={organizationTypeDataState}
                        dataStateChange={onOrganizationTypeDatastateChange}
                        itemChange={organizationTypeItemChange}
                        createOrganizationType={CreateOrganizationType}
                        saveOrganizationType={saveOrganizationType}
                        dragStart={organizationtypeDragStart}
                        reorder={organizationTypeReorder}
                        sortBy={sortBy.organizationType}
                        handleSortByChange={handleSortByChange}
                    />
                )}

                {selectedPage === "Supplier Activity Authorized" && (
                    <SupplierActivityTable
                        KEY={SUPPLIER_ACTIVITY_DATA_ITEM_KEY}
                        columnPropsBuilder={supplierActivityColumnPropsBuilder}
                        supplierActivityData={supplierActivityData}
                        dataState={supplierActivityDataState}
                        dataStateChange={onSupplierActivityDataStateChange}
                        itemChange={supplierActivityItemChange}
                        createSupplierActivity={CreateSupplierActivity}
                        saveSupplierActivity={onSaveSupplierActivity}
                        dragStart={supplierActivityMasterTableDragStart}
                        reorder={supplierActivityMastereorder}
                        sortBy={sortBy.supplierActivity}
                        handleSortByChange={handleSortByChange}
                    />
                )}

                {selectedPage === "Organization" && (
                    <OrganizationTable
                        KEY={ORGANIZATION_DATA_ITEM_KEY}
                        columnPropsBuilder={OrganizationColumnPropsBuilder}
                        organizationData={organizationData}
                        dataState={organizationDataState}
                        dataStateChange={onOrganizationDatastateChange}
                        itemChange={organizationItemChange}
                        createOrganization={CreateOrganization}
                        saveOrganization={saveOrganization}
                        dragStart={organizationDragStart}
                        reorder={organizationMasteReorder}
                        sortBy={sortBy.organization}
                        handleSortByChange={handleSortByChange}
                    />
                )}

            </div>

        </div>
    );
};

export default TableMaintenance;
