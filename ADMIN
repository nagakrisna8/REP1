            reorderData.splice(prevIndex, 1);
            reorderData.splice(nextIndex, 0, supplierCategoryActiveItem || reorderData[0]);
            let sorOrderIndex: number = 1;
            reorderData.forEach((row) => {
                row.SORT_ORDER = sorOrderIndex;
                sorOrderIndex++;
            });
            setSupplierCategoryData(reorderData);
        }

        setDirtyFlag(true);
    }
    const supplierCategoryTypeItemChange = async (event: GridItemChangeEvent) => {
        let tempSupplierCategoryType = [...supplierCategoryData];
        const match = tempSupplierCategoryType.findIndex((i) => i.CATEGORYID === event.dataItem.CATEGORYID);

        if (match !== -1 && event.field) {
            tempSupplierCategoryType[match] = event.dataItem;
            setSupplierCategoryData(tempSupplierCategoryType);
            setDirtyFlag(true);
        }
    };
    const CreateSupplierCategory = () => {
        const newSupplierCategory: SupplierCategoryMasterTable = {
            CATEGORYID: new Date().getTime(),
            CATEGORYDESCRIPTION: "",
            newFlag: true,
            SORT_ORDER: supplierActivityData.length + 1,
            ISACTIVE: true,

        };
        setSupplierCategoryData([newSupplierCategory, ...supplierCategoryData]);
        setDirtyFlag(true);

    };
    const saveSupplierCategory = async () => {
        if (!dirtyFlag) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "No data to save.",
            }));
            return;
        }

        const current = [...supplierCategoryData];
        const original = [...originalSupplierCategoryData];

        // Validation
        if (current.some((i) => !i.CATEGORYDESCRIPTION || i.CATEGORYDESCRIPTION.trim() === "")) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Please fill details.",
            }));
            return;
        }

        const uniqueCount = new Set(
            current.map((i) => i.CATEGORYDESCRIPTION.trim().toLowerCase())
        ).size;

        if (uniqueCount !== current.length) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Supplier Type must be unique.",
            }));
            return;
        }

        // 🔥 Detect changes
        const items: MasterDataItem[] = [];

        current.forEach((row) => {
            const originalRow = original.find(o => o.CATEGORYID === row.CATEGORYID);

            // 🟢 New row
            if (!originalRow) {
                items.push({
                    Id: 0,
                    OperationType: "add",
                    Name: "",
                    Description: row.CATEGORYDESCRIPTION.trim(),
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId:0
                });
            }
            // 🟡 Updated row
            else if (
                originalRow.CATEGORYDESCRIPTION !== row.CATEGORYDESCRIPTION ||
                originalRow.ISACTIVE !== row.ISACTIVE ||
                originalRow.SORT_ORDER !== row.SORT_ORDER
            ) {
                items.push({
                    Id: row.CATEGORYID,
                    OperationType: "update",
                    Name: "",
                    Description: row.CATEGORYDESCRIPTION.trim(),
                    IsActive: row.ISACTIVE ? "Y" : "N",
                    Notes: "",
                    Address: "",
                    Department: "",
                    Phone: "",
                    Email: "",
                    Title: "",
                    orgTypeId:0
                });
            }
        });

        if (items.length === 0) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "No changes detected.",
            }));
            return;
        }

        const payload: MasterDataPayload = {
            MasterDataType: "SupplierCategory",
            Items: items,
        };

        try {
            await EasaListService.addMasterDataType(payload);

            setDirtyFlag(false);
            fetchSupplierCategory();

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Supplier Category saved successfully.",
            }));
        } catch (error) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Error saving Supplier Category.",
            }));
        }
    };
    const fetchSupplierCategory = () => {
        let masterdataType = 2;
        EasaListService.getAdminMasterDetailsType(masterdataType)
            .then((response) => {
                let result: SupplierCategoryMasterTable[] = response?.data.map(category => ({
                    CATEGORYID: category.CATEGORYID,
                    CATEGORYDESCRIPTION: category.CATEGORYDESCRIPTION,
                    ISACTIVE: category.ISACTIVE === "Y",
                }));
                setSupplierCategoryData([...result].reverse());
                setOriginalSupplierCategoryData([...result].reverse());
            })
            .catch((err) => console.error(err));
    };
    const onSupplierCategoryDatastateChange = (event: GridDataStateChangeEvent) => {
        setSupplierCategoryDataState(event.dataState)
    };
    const supplierCategoryColumnPropsBuilder = (field) => {
        return {
            field: field,
            columnMenu: ColumnMenuBuilder,
            headerClassName: isColumnActive(field, supplierCategoryDataState) ? "active kgrid-oss-checklistType-header" : "kgrid-oss-checklistType-header",
        };
    };
    //sorting functionality
    const handleSortByChange = (key: keyof SortByData, value: 'custom' | 'asc' | 'desc', setScreenDirty: boolean = true) => {
        if (key === 'organization') {
            let ascCategoryData: CategoryTypeTable[] = [...categoryTypeGridData];

            if (value === 'asc' || value === 'desc') {
                ascCategoryData = _.orderBy(ascCategoryData, ["CategoryType"], [value]);

                let i = 1;
                ascCategoryData = ascCategoryData.map(x => ({ ...x, Sorting: i++ }));
                setCategoryTypeGridData(ascCategoryData);
            }
        }

        if (key === 'organizationType') {
            let ascChecklistData: OrganizationTypeMasterTable[] = [...organizationTypeData];

            if (value === 'asc' || value === 'desc') {
                ascChecklistData = _.orderBy(ascChecklistData, ["ORGANIZATIONTYPE"], [value]);

                let i = 1;
                ascChecklistData = ascChecklistData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setOrganizationTypeData(ascChecklistData);
            }
        }

        if (key === 'supplierCategory') {
            let ascChecklistData: SupplierCategoryMasterTable[] = [...supplierCategoryData];

            if (value === 'asc' || value === 'desc') {
                ascChecklistData = _.orderBy(ascChecklistData, ["CATEGORYDESCRIPTION"], [value]);

                let i = 1;
                ascChecklistData = ascChecklistData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setSupplierCategoryData(ascChecklistData);
            }
        }

        if (key === 'supplierActivity') {
            let ascErrorCodeData: SupplierActivityMasterTable[] = [...supplierActivityData];

            if (value === 'asc' || value === 'desc') {
                ascErrorCodeData = _.orderBy(ascErrorCodeData, ["ACTIVITYCATEGORY"], [value]);

                let i = 1;
                ascErrorCodeData = ascErrorCodeData.map(x => ({ ...x, SORT_ORDER: i++ }));
                setSupplierActivityData(ascErrorCodeData);
            }
        }

        setSortBy({ ...sortBy, [key]: value });
        if (setScreenDirty) {
            setDirtyFlag(true);
        }
    }

    //Handle fetching Register Types Asynchronously
    const fetchMasterDataTypes = async () => {
        const result = await EasaListService.getAdminMasterData();
        const data = result?.data ?? [];
        setMasterDataOptions(data);

        console.log(result, data, 'data');
    };
    const handleOrg = (event) => {
        const orgTypeId = event.target.value;
        setSelectedOrgId(orgTypeId);
        fetchOrganization(orgTypeId);
    }
    useEffect(() => {
        if (selectedOrgId) {
            fetchOrganization(selectedOrgId);
        }
    }, [selectedOrgId])
    useEffect(() => {
        var storageService = new StorageService();
        let isItarApp = storageService.getIsItarApp();
        setIsItarAppFlag(isItarApp == "Y" ? true : false);
        fetchOrganizationType();
        fetchSupplierCategory();
        fetchSupplierActivity();
    }, []);
    React.useEffect(() => {
        const reversed = [...organizationTypeData].reverse();
        if (!selectedOrgId && reversed.length > 0) {
            setSelectedOrgId(reversed[0].ORGANIZATIONTYPEID as any);
        }
    }, [organizationTypeData, selectedOrgId]);
    useEffect(() => {
        const storageService = new StorageService();
        storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, dirtyFlag);

        return () => {
            storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, false);
        };
    }, [dirtyFlag]);
    useEffect(() => {
        fetchMasterDataTypes();
    }, []);
    console.log(organizationTypeData, supplierCategoryData, supplierActivityData, 'organizationTypeData');
    return (
        <div className="FPQDetails-Admin-table-maintenance">
            <div className="FPQDetails-Admin-table-maintenance-topbar">
                <div>Master Data</div>
                <Select id="admin-table-page-selector" style={{ maxWidth: isItarAppFlag ? 280 : 210, minWidth: isItarAppFlag ? 280 : 210 }} value={selectedPage} onChange={handlePageChange} size="medium">
                    {Options.map((item) => (
                        <MenuItem
                            key={item}
                            value={item}
                            className="text-normal"
                        >
                            {item}
                        </MenuItem>
                    ))}
                </Select>
                {selectedPage === "Organization" && (
                    <div style={{ marginLeft: 16, display: "flex", gap: 8, justifyContent: "flex-start", alignItems: "center", fontSize: 14 }}>
                        Organization Type
                        <Select id="admin-table-page-selector" style={{ maxWidth: isItarAppFlag ? 280 : 210, minWidth: isItarAppFlag ? 280 : 210 }} value={selectedOrgId} onChange={handleOrg} size="medium"
                            MenuProps={{
                                PaperProps: {
                                    sx: {
                                        height: 170,
                                        overflowY: "auto"
                                    }
                                }
                            }}
                        >{([...organizationTypeData]
                            .filter(item => item.ISACTIVE === true)   
                            .reverse()
                        ).map(item => (
                            <MenuItem
                                key={item.ORGANIZATIONTYPEID}
                                value={item.ORGANIZATIONTYPEID}
                                className="text-normal"
                            >
                                {item.ORGANIZATIONTYPE}
                            </MenuItem>
                        ))}
                        </Select>
                    </div>
                )}
            </div>

            <div className="FPQDetails-Admin-table-maintenance-section">
                {selectedPage === "Supplier Category" && (
                    <>
                        <SupplierCategoryTable
                            key="kgrid-oss-admin-table-checklistType-comp"
                            columnPropsBuilder={supplierCategoryColumnPropsBuilder}
                            KEY={SUPPLIER_CATEGORY_DATA_ITEM_KEY}
                            supplierCategoryData={supplierCategoryData}
                            dataState={supplierCategoryDataState}
                            dataStateChange={onSupplierCategoryDatastateChange}
                            itemChange={supplierCategoryTypeItemChange}
                            createSupplierCategory={CreateSupplierCategory}
                            saveSupplierCategory={saveSupplierCategory}
                            dragStart={supplierCategoryMasterTableDragStart}
                            reorder={supplierCategoryMasterReorder}
                            sortBy={sortBy.supplierCategory}
                            handleSortByChange={handleSortByChange}
                        />
                    </>
                )}

                {
                    selectedPage === "Organization" && (
                        <OrganizationTable
                            key="kgrid-oss-admin-table-errorCode-comp-1"
                            KEY={ORGANIZATION_DATA_ITEM_KEY}
                            columnPropsBuilder={OrganizationColumnPropsBuilder}
                            organizationData={organizationData}
                            dataState={organizationDataState}
                            dataStateChange={onOrganizationDatastateChange}
                            itemChange={organizationItemChange}
                            createOrganization={CreateOrganization}
                            saveOrganization={saveOrganization}
                            dragStart={organizationDragStart}
                            reorder={organizationMasteReorder}
                            sortBy={sortBy.supplierActivity}
                            handleSortByChange={handleSortByChange}
                        />
                    )
                }

                {selectedPage === "Organization Type" && (
                    <OrganizationTypeTable
                        key="kgrid-oss-admin-table-checklistType-comp"
                        KEY={ORGANIZATION_TYPE_DATA_ITEM_KEY}
                        columnPropsBuilder={organizationTypeColumnPropsBuilder}
                        organizationTypeData={organizationTypeData}
                        dataState={organizationTypeDataState}
                        dataStateChange={onOrganizationTypeDatastateChange}
                        itemChange={organizationTypeItemChange}
                        createOrganizationType={CreateOrganizationType}
                        saveOrganizationType={saveOrganizationType}
                        dragStart={organizationtypeDragStart}
                        reorder={organizationTypeReorder}
                        sortBy={sortBy.organizationType}
                        handleSortByChange={handleSortByChange}
                    />
                )}

                {selectedPage === "Supplier Activity Authorized" && (
                    <SupplierActivityTable
                        key="kgrid-oss-admin-table-errorCode-comp-1"
                        KEY={SUPPLIER_ACTIVITY_DATA_ITEM_KEY}
                        columnPropsBuilder={supplierActivityColumnPropsBuilder}
                        supplierActivityData={supplierActivityData}
                        dataState={supplierActivityDataState}
                        dataStateChange={onSupplierActivityDataStateChange}
                        itemChange={supplierActivityItemChange}
                        createSupplierActivity={CreateSupplierActivity}
                        saveSupplierActivity={onSaveSupplierActivity}
                        dragStart={supplierActivityMasterTableDragStart}
                        reorder={supplierActivityMastereorder}
                        sortBy={sortBy.supplierActivity}
                        handleSortByChange={handleSortByChange}
                    />
                )}



            </div>
        </div>
    );
};

