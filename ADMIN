            const trimmed = String(orgTypeOrName).trim();
            // Try find by display name in organizationTypes
            const matchByName = organizationTypes.find(
                (t) => String(t.OrgType).trim() === trimmed
            );
            if (matchByName && matchByName.OrgTypeId != null) {
