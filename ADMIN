                              if (!props.dataItem) {
                                return <td style={{ verticalAlign: "top" }} />;
                              }
                              const titleText = `${props.dataItem.PMDBPROJECTTITLE ?? ""}${props.dataItem?.DOCUMENTCONTENT ? `\n${props.dataItem.DOCUMENTCONTENT}` : ""}`;
                              return (
                                <td
                                  style={{ verticalAlign: "top", whiteSpace: "normal", wordWrap: "break-word" }}
                                  title={titleText}
                                >
                                  <div style={{ paddingTop: '7px' }}>
                                    <div>{props.dataItem.PMDBPROJECTTITLE}</div>
                                    {props.dataItem?.DOCUMENTCONTENT ? (
                                      <span style={{ fontStyle: "italic", color: "#008000", marginTop: "5px", display: "inline-block" }}>
                                        {props.dataItem.DOCUMENTCONTENT}
                                      </span>
                                    ) : null}
                                  </div>
                                </td>
                              );
                            }
                          }}
                        />
                      );
                    }
                    if (col.field === "REVLEVEL") {
                      return (
                        <GridColumn
                          key={index}
                          {...columnProps(col.field)}
                          field={col.field}
                          width={col.width}
                          title={col.title}
                          cells={{
                            data: props => <td style={{ verticalAlign: "top", textAlign: "center" }} title={props.dataItem.REVLEVEL}>
                              <div style={{ paddingTop: '7px' }}>{props.dataItem.REVLEVEL}</div>
                            </td>
                          }}
                        />
                      )
                    }
                    if (col.field === "STATUS") {
                        return (
                            <GridColumn
                                key={index}
                                {...columnProps(col.field)}
                                field={col.field}
                                width={col.width}
                                title={col.title}
                                cells={{ data: (props: any) => CustomStatusDropDown(props, getStatusList) }}
                            />
                        )
                    }
                    if (col.field === "PURPOSE") {
                      return (
                        <GridColumn
                          key={index}
                          {...columnProps(col.field)}
                          field={col.field}
                          width={col.width}
                          title={col.title}
                          cells={{ data: (props: any) => CustomDropDown(props, getPurposeList) }}
                        />
                      )
                    }
                    return (
                      <GridColumn
                        key={index}
                        {...columnProps(col.field)}
                        field={col.field}
                        title={col.title}
                        width={col.width}
                      />
                    );
                  }
                })}
              </AnyGrid>
            ) : <div style={{ height: "300px", width: "100%" }}></div>}
          </Typography>

          <Typography id="modal-modal-btn" className='button-Insert' sx={{ mt: 2 }} textAlign={"end"} style={{ padding: '13px 0 0 0' }}>
            <Button
              className="button-style-create-new"
              variant="contained"
              size='small'
              onClick={() => { props.IsManageSupTab ? InsertSupportingDataInManageTab() : onInsertSupportingCheckedItemClick() }}
              disabled={selectedSupProject.length == 0 ? true : false}
              style={{ fontSize: '14px', backgroundColor: "#0033A1", color: 'white', textTransform: 'capitalize', height: '32px', padding: '8px 10px' }}
            >
              Insert
            </Button>
          </Typography>
        </Box>
      </Modal>

      {/* ----------------------- Attachment modal --------------------------- */}
      <Modal
        open={attachmentModal}
        onClose={closeEspecAttachmentModal}
        aria-labelledby="nested-modal-title"
        aria-describedby="nested-modal-description"
        sx={{ zIndex: "1" }}
      >
        <Box sx={{ ...modalStyle, width: "800", padding: "24px" }}>
          <div className="modal-heading" style={{ display: "flex", justifyContent: "space-between", marginLeft: '-6px' }}>
            <span className="titleSection">
              <Typography variant="h5" gutterBottom className="com-att-titleBody" style={{ display: "flex" }} >
                <AttachFileIcon style={{ marginRight: "4px", marginTop: "4px" }} />
                <span style={{ margin: "0", height: "24px" }}>
                  {popUpHeader}
                </span>
              </Typography>
            </span>
            <CloseIcon
              style={{ cursor: "pointer" }}
              className="com-att-closeIcon"
              onClick={() => closeEspecAttachmentModal()}
            />
          </div>
          <Typography id="com-att-modal-modal-btn" style={{ padding: '0px' }} className='com-att-cmdAttachmentGrid' variant="h6" component="h2">
            <Grid
              id="com-att-popupGridStyling"
              data={getAttachDocData}
              onDataStateChange={attachgriddatastatechange}
              {...attachDocdataState}
              sortable={true}
              columnMenuIcon={filterIcon}
              style={{
                height: attachmentData.length == 0 ? "150px" : "250px",
                width: "100%",
                marginTop: '32px'
              }}
            >
              <GridColumn {...attachColumnProps('Filename') as any} field="Filename" title="File Name" cells={{
                data: (props) => (
                  <td title={props.dataItem.Filename}>
                    <Button
                      variant={"text"}
                      sx={{
                        fontSize: "14px",
                        padding: 0,
                        justifyContent: "flex-start",
                        color: '#0078B8',
                        textOverflow: "ellipsis",
                        overflow: "hidden",
                        marginLeft: '12px',
                        textTransform: 'none',
                        "&:hover": {
                          backgroundColor: "transparent",
                        },
                      }}
                      onClick={() => onClickUrl(props.dataItem.Url)}
                    >
                      {props.dataItem.Filename}
                    </Button>
                  </td>
                )
              }} />
              <GridColumn {...attachColumnProps('CreatedByName') as any} field="CreatedByName" title="Created By" width="200px" cell={(props) => (
                <td title={props.dataItem.CreatedByName} className="createdBy">
                  <Button
                    variant={"text"}
                    sx={{
                      fontSize: "14px",
                      padding: 0,
                      justifyContent: "flex-start",
                      // color:'#0078B8',
                      marginLeft: '12px',
                      textTransform: 'none',
                      "&:hover": {
                        backgroundColor: "transparent", // Set the background color to transparent on hover
                      },
                    }}
                  >
                    {props.dataItem.CreatedByName}
                  </Button>
                </td>
              )} />
              <GridColumn {...attachColumnProps('CreationDateStr') as any} field="CreationDateStr" title="Creation Date" width="150px" filter="date"
                filterCell={(props) => (
                  <DatePicker
                    {...props}
                    value={props.value ? new Date(`${props.value}`) : null}
                    format="MM-dd-yyyy" // Specify the format for the date picker
                    onChange={(event) => {
                      props.onChange({
                        value: event.target.value instanceof Date ? event.target.value : null,
                        operator: 'eq', // You can adjust the operator as needed
                        syntheticEvent: event.nativeEvent,
                      });
                    }}
                  />
                )}
                cell={(props) => {
                  const modificationDate = props.dataItem.CreationDateStr ? new Date(props.dataItem.CreationDateStr) : null;
                  return (
                    <td title={modificationDate ? modificationDate.toLocaleDateString(undefined, { month: '2-digit', day: '2-digit', year: 'numeric' }) : ""}>
                      <Button
                        variant={"text"}
                        sx={{
                          fontSize: "14px",
                          padding: 0,
                          justifyContent: "flex-start",
                          marginLeft: '12px',
                          textTransform: 'none',
                          color: "#253746",
                          "&:hover": {
                            backgroundColor: "transparent", // Set the background color to transparent on hover
                          },
                        }}
                      >
                        {modificationDate && modificationDate.toLocaleDateString(undefined, { month: '2-digit', day: '2-digit', year: 'numeric' })}
                      </Button>
                    </td>
                  )
                }} />
            </Grid>
          </Typography>
          <Typography className="com-att-close-btn" id="com-att-modal-modal-btn" sx={{ mt: 2 }} textAlign={"end"}>
            <Button
              className="com-att-closeIconCmdAttachment"
              variant="contained"
              size='small'
              onClick={closeEspecAttachmentModal}
              style={{ fontSize: '14px', textTransform: "capitalize" }}
            >
              Close
            </Button>
          </Typography>
        </Box>
      </Modal>
    </>
  );
};

export default SupportingInsertPopupData;
