const customTextArea = (props) => {
  const { dataItem, field, onChange } = props;
  const [value, setValue] = useState(dataItem[field]);

  const handlecustomTextAreaChange = (event) => {
    const newValue = event.target.value;
    setValue(newValue);
    onChange({
      dataItem,
      field,
      syntheticEvent: event,
      value: newValue
    });
  };

  return (
    <td>
      <TextArea value={value} style={{ borderRadius: "4px", border: "1px solid rgba(0, 0, 0, 0.23)" }} onChange={handlecustomTextAreaChange} rows={3} title={value} autoSize={true} />
    </td>
  );
};

const CustomInputText = (props) => {
  const { dataItem, field, onChange } = props;
  const [value, setValue] = useState(dataItem[field]);

  useEffect(() => {
    // to remove html while loading data
    setValue(commonFunction.removeHTMLTags(dataItem[field]));
  }, [dataItem, field]);
  const handlecustomTextAreaChange = (event) => {
    const newValue = event.target.value;
    setValue(newValue);
    onChange({
      dataItem,
      field,
      syntheticEvent: event,
      value: commonFunction.removeHTMLTags(newValue) // to remove html while editing
    });
  };

  return (
    <td style={{ verticalAlign: "top" }}>
      <div style={{ paddingTop: '7px', paddingBottom: '7px' }}>
        <TextBox className={field == "DOCUMENTNUMBER" ? `othersDocNum-${value?.toLowerCase()}` : ''} value={value} style={{ borderRadius: "4px", border: "1px solid rgba(0, 0, 0, 0.23)", height: 32 }} onChange={handlecustomTextAreaChange} maxLength={1000} title={value} />
      </div>
    </td>
  );
};

const CustomDropDown = (props, getPurposeList: GetRegulationPurposeData[]) => {
  const { dataItem } = props;
  const field = props.field || '';
  const [inputValue, setInputValue] = useState(dataItem[field]);
  const handleMultiChange = (event) => {
    const newVal = event.target.value;
    setInputValue(newVal);
    if (props.onChange) {
      let tempNewData = props.dataItem;
      props.onChange({
        dataIndex: 0,
        dataItem: tempNewData,
        field: props.field,
        syntheticEvent: event,
        value: newVal ? newVal : "",
      });
    }
  };

  return (
    <td  className="purpose-dropdown">
      <Select
        className="supp-inputSelect-Box"
        labelId="suppporting-simple-select-label"
        value={inputValue}
        title={inputValue}
        sx={{ fontSize: '14px', backgroundColor: '#FFFFFF', color: '#253746', fontWeight: "normal", display: 'block' }}
        input={<OutlinedInput placeholder="Model" />}
        onChange={(event) => handleMultiChange(event)}
        disabled={dataItem.Disable}
        renderValue={(selected) => selected.length == 0 ? "No option selected" : inputValue}
        placeholder='No Options Selected'
      >
        {getPurposeList &&
          getPurposeList?.map((option) => (
            <MenuItem key={option.MasterId} value={option.MasterValue} style={{ height: "32px" }}>
              <ListItemText primary={option.MasterValue} primaryTypographyProps={{ fontSize: '14px', color: '#253746', fontWeight: "normal" }} />
            </MenuItem>
          ))}
      </Select>
    </td>
  );
};

