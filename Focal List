import "../AdminTable.scss";
import React, { memo, useCallback, useEffect, useRef } from "react";
import { FocalMasterTable, SortByData } from "../AdminModal";
import { State, process } from "@progress/kendo-data-query";
import {
    Grid as DataGrid,
    GridCellProps,
    GridColumn,
    GridColumnMenuFilter,
    GridColumnMenuProps,
    GridDataStateChangeEvent,
    GridItemChangeEvent,
    GridToolbar
} from "@progress/kendo-react-grid";

import {
    Box,
    Button,
    Card,
    FormControl,
    MenuItem,
    Select,
    TextField,
    Typography
} from "@mui/material";

import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import SettingsIcon from "@mui/icons-material/Settings";
import ArrowUpwardIcon from "@mui/icons-material/ArrowUpward";
import ArrowDownwardIcon from "@mui/icons-material/ArrowDownward";
import SortIcon from "@mui/icons-material/Sort";
import GroupIcon from "@mui/icons-material/Group";
import ArrowDropDownIcon from "@mui/icons-material/ArrowDropDown";
import ArrowDropUpIcon from "@mui/icons-material/ArrowDropUp";

import { filterIcon } from "@progress/kendo-svg-icons";
import FocalForm from "../Focal/FocalForm";

const editField = "inEdit";
const SELECTED_FIELD = "selected";
const AnyGrid = DataGrid as any;

const GridFilterMenuWithoutSort = (props: GridColumnMenuProps) => (
    <div>
        <GridColumnMenuFilter {...props} expanded />
    </div>
);
interface FocalTableProps {
    KEY: string;
    columnPropsBuilder: (field: any) => { field: any; columnMenu: (props: any) => JSX.Element; headerClassName: string };
    focalData: FocalMasterTable[];
    dataState: State;
    dataStateChange: (event: GridDataStateChangeEvent) => void;
    itemChange: (event: GridItemChangeEvent) => void;
    createFocal: () => void;
    saveFocal: () => void;
    fetchFocal: () => void;
    dragStart: (dataItem: FocalMasterTable) => void;
    reorder: (dataItem: FocalMasterTable) => void;
    sortBy: "custom" | "asc" | "desc" | undefined;
    handleSortByChange: (key: keyof SortByData, value: "custom" | "asc" | "desc", setScreenDirty?: boolean) => void;
}

const FocalTable: React.FC<any> = memo((props) => {

    const gridRefBuilder = useRef<any>(null);

    // expansion state
    const [detailExpand, setDetailExpand] = React.useState<{ [key: number]: boolean }>({});

    const expandChange = (dataItem: any) => {

        const key = dataItem.ID;

        setDetailExpand(prev => ({
            ...prev,
            [key]: !prev[key]
        }));
    };

    const gridData = process(props.focalData, props.dataState).data;

    const OrganizationCell: React.ComponentType<GridCellProps> = useCallback(
        (cellProps) => {

            const field = cellProps.field || "";
            const value = cellProps.dataItem[field] ?? "";

            const handleChange = (e: any) => {

                const updated = { ...cellProps.dataItem };
                updated[field] = e.target.value;

                cellProps.onChange?.({
                    dataIndex: cellProps.dataIndex,
                    dataItem: updated,
                    field,
                    syntheticEvent: e,
                    value: e.target.value
                });
            };

            return (
                <td>
                    <TextField fullWidth value={value} onChange={handleChange} />
                </td>
            );
        },
        []
    );

    const DragCell: React.ComponentType<GridCellProps> = (dragcellprops) => (
        <td
            onDragOver={(e) => {
                e.preventDefault();
                props.reorder(dragcellprops.dataItem);
            }}
        >
            <span
                draggable
                style={{
                    cursor: "move",
                    display: "flex",
                    justifyContent: "center"
                }}
                onDragStart={() => props.dragStart(dragcellprops.dataItem)}
            >
                <SortIcon />
            </span>
        </td>
    );

    // Custom arrow column
    const ContactFocals: React.ComponentType<GridCellProps> = (cellProps) => {

        const expanded = detailExpand[cellProps.dataItem.ID];

        const toggle = (e: React.MouseEvent) => {
            e.stopPropagation();
            expandChange(cellProps.dataItem);
        };

        return (
            <td>
                <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                    <span
                        onClick={toggle}
                        style={{ cursor: "pointer", display: "flex" }}
                    >
                        {expanded ? <ArrowDropUpIcon /> : <ArrowDropDownIcon />}
                    </span>
                </div>
            </td>
        );
    };

    const DetailComponent = (detailProps: any) => {

        // const orgName = detailProps.dataItem.ORGANIZATIONNAME;

        return (
            <div>
                <FocalForm  focalData ={detailProps.dataItem} saveFocal={props.saveFocal}/>
            </div>
        );
    };
    const FocalInformationCell: React.ComponentType<GridCellProps> = (cellProps) => {

        const dataItem = cellProps.dataItem;

        return (
            <td>
                <div style={{ display: "flex", gap: "12px" }}>
                    <span style={{ minWidth: "120px" }}>
                        {dataItem.ADDRESS || ""}
                    </span>
                    <span style={{ minWidth: "120px" }}>
                        {dataItem.PHONENO || ""}
                    </span>
                    <span style={{ minWidth: "120px" }}>
                        {dataItem.POSITION || ""}
                    </span>

                    <span style={{ minWidth: "180px" }}>
                        {dataItem.EMAIL || ""}
                    </span>
                </div>
            </td>
        );
    };
    const activeCheckbox: React.ComponentType<GridCellProps> = (cellProps) => {
        const dataItem = cellProps.dataItem;

        const handleChange = (e: any) => {
            const updated = {
                ...dataItem,
                ISACTIVE: e.target.checked
            };

            cellProps.onChange?.({
                dataIndex: cellProps.dataIndex,
                dataItem: updated,
                field: cellProps.field,
                syntheticEvent: {} as React.SyntheticEvent,
                value: e.target.checked
            });
        };

        return (
            <td>
                <div style={{ display: "flex", justifyContent: "center" }}>
                    <input
                        type="checkbox"
                        checked={dataItem.ISACTIVE}
                        onChange={handleChange}
                    />
                </div>
            </td>
        );
    };

useEffect(() => {

    if (props.focalData && props.focalData.length > 0) {

        const lastItem = props.focalData[props.focalData.length - 1];

        if (lastItem?.inEdit) {

            setDetailExpand(prev => ({
                ...prev,
                [lastItem.ID]: true
            }));

        }
    }

}, [props.focalData]);
    return (
        <div style={{ paddingBottom: 20 }}>

            <Card style={{ borderLeft: "4px solid #0033A1", marginLeft: 22 }}>

                <AnyGrid
                    ref={gridRefBuilder}
                    className="focal-grid-compact"
                    style={{ height: "80vh" }}
                    data={gridData}
                    dataItemKey="ID"
                    resizable
                    editField={editField}
                    {...props.dataState}
                    selectedField={SELECTED_FIELD}
                    onDataStateChange={props.dataStateChange}
                    onItemChange={props.itemChange}
                    columnMenuIcon={filterIcon}
                    detail={DetailComponent}
                    detailExpand={detailExpand}
                >

                    <GridToolbar key="grid-toolbar">
                        {
                            <Button
                                className="easalist-marginLeft10"
                                id="createBtn"
                                title="Create New"
                                onClick={props.createFocal}
                                size={"small"}
                                color={"inherit"}
                                variant={"outlined"}

                            >
                                <AddCircleOutlineIcon className="iconClass" />
                                <Typography
                                    variant={"button"}
                                    sx={{ textTransform: "none", fontSize: "14px" }}
                                >
                                    Create New
                                </Typography>
                            </Button>
                        }
                        {
                            < Button
                                className="easalist-marginLeft10"
                                id="deleteBtn"
                                title="Delete"
                                onClick={props.saveFocal}
                                variant={"outlined"}
                                size={"small"}
                                color={"inherit"}
                            >
                                <Typography
                                    variant={"button"}
                                    sx={{ textTransform: "none", fontSize: "14px" }}
                                >
                                    Save
                                </Typography>
                            </Button >
                        }
                        {
                            <Box
                                sx={{
                                    display: "flex",
                                    alignItems: "center",
                                    gap: 1.5,
                                    position: "absolute",
                                    right: 20,
                                }}
                            >
                                <Typography
                                    variant="body2"
                                    sx={{
                                        color: "#253746",
                                        fontWeight: 500,
                                        whiteSpace: "nowrap",
                                    }}
                                >
                                    Sort Order :
                                </Typography>
                                <FormControl variant="outlined">
                                    <Select
                                        id="register-type-select-dropdown"
                                        className="text-normal"
                                        style={{
                                            width: "200px",
                                            height: "32px",
                                            fontSize: "14px",
                                            color: "#253746",
                                        }}
                                        value={props.sortBy || "custom"}
                                        onChange={(e) =>
                                            props.handleSortByChange(
                                                "focal",
                                                e.target.value as "custom" | "asc" | "desc"
                                            )
                                        }
                                    >
                                        <MenuItem value="custom">
                                            <SettingsIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                                            Customize
                                        </MenuItem>
                                        <MenuItem value="asc">
                                            <ArrowUpwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                                            Focal Management: Ascending
                                        </MenuItem>
                                        <MenuItem value="desc">
                                            <ArrowDownwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                                            Focal Management : Descending
                                        </MenuItem>
                                    </Select>
                                </FormControl>
                            </Box>
                        }
                    </GridToolbar >
                    <GridColumn
                        {...props.columnPropsBuilder("NAME")}
                        title="Focal Name"
                        //cells={{ data: OrganizationCell }}
                        width="240px"
                    />
                    <GridColumn
                        title="Focal Information"
                        cells={{ data: FocalInformationCell }}
                        width="720px"
                    />
                    <GridColumn
                        {...props.columnPropsBuilder("ISACTIVE")}
                        title="Active"
                        cells={{ data: activeCheckbox }}
                        width="90px"
                    />
                    <GridColumn
                        title="Focals"
                        cells={{ data: ContactFocals }}
                        width="150px"
                    />
                </AnyGrid>
            </Card>
        </div>
    );
});

export default FocalTable;
