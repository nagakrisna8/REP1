import React, { memo, useEffect, useState, useRef } from "react";
import { Grid as DataGrid, GridColumn } from "@progress/kendo-react-grid";
import { State, process } from "@progress/kendo-data-query";
import EasaListService from "../../EasaRegisterListService";
import "./FocalList.scss";
import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import { Button, Divider, Typography } from "@mui/material";

const AnyGrid = DataGrid as any;

interface FocalData {
    NAME: string;
    ADDRESS: string;
    PHONE: number;
    DEPARTMENT: string;
    EMAIL: string;
}

interface FocalListProps {
    orgName: number;
    orgType: number;
    onCreateFocal: (orgId: number, orgTypeId: number) => void
}

const FocalList: React.FC<FocalListProps> = memo(({ orgName, orgType, onCreateFocal }) => {

    const [focalListData, setFocalListData] = useState<FocalData[]>([]);
    const [dataState, setDataState] = useState<State>({});
    const [calculatedDynamicColWidth, setCalculatedDynamicColWidth] = useState(0);
    const [totalColumnFixedWidth, setTotalColumnFixedWidth] = useState(0);
    const [activeTab, setActiveTab] = useState<"list" | "add">("list");

    const fetchFocalList = async (orgType: number, organization: number) => {



        const masterdataType = 4;

        try {

            const response =
                await EasaListService.getAdminMasterDetailsTypeFocals(
                    masterdataType,
                    orgType,
                    organization,
                );

            const result: FocalData[] = response?.data.map((x: any) => ({
                NAME: x.NAME,
                ADDRESS: x.ADDRESS,
                PHONE: x.PHONE,
                DEPARTMENT: x.POSITION,
                EMAIL: x.EMAIL
            }));

            setFocalListData(result);

        } catch (error) {
            console.error("Error fetching focal list:", error);
        }
    };
    const setPercentage = (width = 0, percentage = 0, minWidth = 0) => {
        let k_grid_width = document.querySelector("#kgrid-oss-checklistType")?.clientWidth;
        let fixedWidth = totalColumnFixedWidth;
        let dynamicWidth = 0;
        let minScreenWidth = 1250;
        let maxScreenWidth;
        if (k_grid_width) {
            if (k_grid_width <= minScreenWidth) {
                return minWidth;
            }
            else {
                dynamicWidth = k_grid_width - fixedWidth;
                if (width == 0 && dynamicWidth > 0 && percentage > 0) {
                    const dynamicColumnWidth = Math.round(dynamicWidth * (percentage / 100));
                    return Math.max(minWidth, dynamicColumnWidth);
                }
                else {
                    return calculatedDynamicColWidth != 0 ? minWidth > (dynamicWidth - calculatedDynamicColWidth) ? minWidth : undefined : undefined
                }
            }
        }

    }
    useEffect(() => {

        if (!orgName) return;

        fetchFocalList(orgType, orgName);

    }, [orgName, orgType]);

    return (
        <div className="focal-container">
            <div className="focal-header">
                <Button
                    className={`focal-tab ${activeTab === "list" ? "active" : ""}`}
                    onClick={() => setActiveTab("list")}
                    size="small"
                    color="inherit"
                    variant="outlined"
                >
                    <Typography sx={{ textTransform: "none", fontSize: "15px", fontWeight: 600 }}>
                        List of Focals
                    </Typography>
                </Button>

                <Button
                    className={`focal-tab ${activeTab === "add" ? "active" : ""}`}
                    onClick={() => {
                        setActiveTab("add");
                        onCreateFocal(orgName, orgType);
                    }}
                    size="small"
                    color="inherit"
                    variant="outlined"
                >
                    <Typography sx={{ textTransform: "none", fontSize: "15px", fontWeight: 600 }}>
                        Add New Focal
                    </Typography>
                </Button>
            </div>

      <AnyGrid
        className="focal-grid"
        scrollable="scrollable"
        data={process(focalListData, dataState)}
        {...dataState}
        onDataStateChange={(e: any) => setDataState(e.dataState)}
      >
        <GridColumn field="" title="Sort" width={setPercentage(undefined, 0, 272)} />
        <GridColumn field="NAME" title="Focal Names" width={setPercentage(undefined, 0, 272)} />
        <GridColumn field="ADDRESS" title="Address" width={setPercentage(undefined, 0, 272)} />
        <GridColumn field="PHONE" title="Phone" width={setPercentage(undefined, 0, 272)} />
        <GridColumn field="DEPARTMENT" title="Position" width={setPercentage(undefined, 0, 272)} />
        <GridColumn field="EMAIL" title="Email" width={setPercentage(undefined, 0, 272)} />
      </AnyGrid>

        </div >
    );
});

export default FocalList;
