import "../AdminTable.scss";
import React, { memo, useCallback, useEffect, useRef, useState } from "react";
import { FocalMasterTable, SortByData } from "../AdminModal";
import { State, process } from "@progress/kendo-data-query";
import SearchIcon from "@mui/icons-material/Search";
import {
    Grid as DataGrid,
    GridCellProps,
    GridColumn,
    GridColumnMenuFilter,
    GridColumnMenuProps,
    GridDataStateChangeEvent,
    GridItemChangeEvent,
    GridToolbar
} from "@progress/kendo-react-grid";

import {
    Box,
    Button,
    Card,
    FormControl,
    IconButton,
    InputAdornment,
    MenuItem,
    Select,
    TextField,
    Typography
} from "@mui/material";

import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import SettingsIcon from "@mui/icons-material/Settings";
import ArrowUpwardIcon from "@mui/icons-material/ArrowUpward";
import ArrowDownwardIcon from "@mui/icons-material/ArrowDownward";
import ArrowDropDownIcon from "@mui/icons-material/ArrowDropDown";
import ArrowDropUpIcon from "@mui/icons-material/ArrowDropUp";

import { filterIcon } from "@progress/kendo-svg-icons";
import FocalForm from "../Focal/FocalForm";
import { useParams } from "react-router-dom";
import EasaRegisterListService from "../../EasaRegisterListService";

const editField = "inEdit";
const AnyGrid = DataGrid as any;

const GridFilterMenuWithoutSort = (props: GridColumnMenuProps) => (
    <div>
        <GridColumnMenuFilter {...props} expanded />
    </div>
);

interface FocalTableProps {
    KEY: string;
    columnPropsBuilder: (field: any) => {
        field: any;
        columnMenu: (props: any) => JSX.Element;
        headerClassName: string;
    };
    focalData: FocalMasterTable[];
    dataState: State;
    dataStateChange: (event: GridDataStateChangeEvent) => void;
    itemChange: (event: GridItemChangeEvent) => void;
    createFocal: () => void;
    saveFocal: () => void;
    setDirtyFlag?: (flag: boolean) => void;
    selectedOrgId: any;
    selectedOrganizationId: any;
    expandFocalId?: number | null;
    fetchFocal: () => void;
    dragStart: (dataItem: FocalMasterTable) => void;
    reorder: (dataItem: FocalMasterTable) => void;
    sortBy: "custom" | "asc" | "desc" | undefined;
    handleSortByChange: (
        key: keyof SortByData,
        value: "custom" | "asc" | "desc",
        setScreenDirty?: boolean
    ) => void;
}

interface BemsSearchInputProps {
    value: string;
    onChange: (value: string) => void;
    onSearch: () => void;
    onEnter: () => void;
}

const BemsSearchInput = React.memo(
    ({ value, onChange, onSearch, onEnter }: BemsSearchInputProps) => {
        return (
            <div style={{ width: "100%" }}>
                <TextField
                    variant="standard"
                    value={value}
                    style={{ width: "100%" }}
                    onChange={(e) => onChange(e.target.value)}
                    onKeyDown={(e) => {
                        if (e.key === "Enter") {
                            onEnter();
                        }
                    }}
                    placeholder="BEMS ID"
                    className="kgrid-oss-csr-lookup-popup-input"
                    inputProps={{
                        style: {
                            fontSize: 14,
                            color: "#253746",
                            fontWeight: "normal"
                        }
                    }}
                    InputProps={{
                        endAdornment: (
                            <InputAdornment position="end">
                                <IconButton
                                    className="kgrid-oss-csr-lookup-popup-search-icon"
                                    onClick={onSearch}
                                >
                                    <SearchIcon />
                                </IconButton>
                            </InputAdornment>
                        )
                    }}
                />
            </div>
        );
    }
);

const FocalTable: React.FC<any> = memo((props) => {
    const gridRefBuilder = useRef<any>(null);
    const [calculatedDynamicColWidth, setCalculatedDynamicColWidth] = useState(0);
    const [totalColumnFixedWidth, setTotalColumnFixedWidth] = useState(0);
    const [detailExpand, setDetailExpand] = useState<{ [key: number]: boolean }>({});
    const [result, setResult] = useState<any>(null);
    const [searchInput, setSearchInput] = useState<{ [key: number]: string }>({});
    const [, forceRefresh] = useState(0);

    const { reportId } = useParams();

    const gridData = process(props.focalData, props.dataState).data;
    const formDataMapRef = useRef<{ [id: number]: any }>({});

    const handleFormChange = useCallback(
        (id: number, data: any) => {
            formDataMapRef.current[id] = data;
            props.setDirtyFlag?.(true);
        },
        [props]
    );

    const clearFormData = useCallback((id: number) => {
        delete formDataMapRef.current[id];
    }, []);

    const cancelFocal = useCallback((id: number) => {
        const row = props.focalData.find((item: any) => item.ID === id);
        if (row?.newFlag) {
            props.focalData.splice(
                props.focalData.findIndex((item: any) => item.ID === id),
                1
            );
        }

        setDetailExpand((prev) => ({
            ...prev,
            [id]: false
        }));

        setSearchInput((prev) => {
            const updated = { ...prev };
            delete updated[id];
            return updated;
        });

        delete formDataMapRef.current[id];
    }, [props.focalData]);

    const expandChange = useCallback((dataItem: any) => {
        const key = dataItem.ID;

        setDetailExpand((prev) => ({
            ...prev,
            [key]: !prev[key]
        }));
    }, []);

    const ContactFocals: React.ComponentType<GridCellProps> = useCallback((cellProps) => {
        const expanded = detailExpand[cellProps.dataItem.ID];

        const toggle = (e: React.MouseEvent) => {
            e.stopPropagation();
            expandChange(cellProps.dataItem);
        };

        return (
            <td>
                <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 6 }}>
                    <span onClick={toggle} style={{ cursor: "pointer", display: "flex" }}>
                        {expanded ? <ArrowDropUpIcon /> : <ArrowDropDownIcon />}
                    </span>
                </div>
            </td>
        );
    }, [detailExpand, expandChange]);

    const DetailComponent = useCallback((detailProps: any) => {
        const id = detailProps.dataItem.ID;
        return (
            <div>
                <FocalForm
                    focalData={detailProps.dataItem}
                    saveFocal={props.saveFocal}
                    fetchFocal={props.fetchFocal}
                    selectedOrgId={props.selectedOrgId}
                    selectedOrganizationId={props.selectedOrganizationId}
                    cancelFocal={cancelFocal}
                    focalList={props.focalData}
                    savedFormData={formDataMapRef.current[id]}
                    onFormChange={(data: any) => handleFormChange(id, data)}
                    clearFormData={() => clearFormData(id)}
                    setDirtyFlag={props.setDirtyFlag}
                />
            </div>
        );
    }, [
        props.saveFocal,
        props.fetchFocal,
        props.selectedOrgId,
        props.selectedOrganizationId,
        props.focalData,
        props.setDirtyFlag,
        cancelFocal,
        handleFormChange,
        clearFormData
    ]);

    const handleSearch = useCallback(
        async (dataItem: any) => {
            const bemsValue = searchInput[dataItem.ID]?.trim();

            if (!bemsValue) return;

            try {
                const response = await EasaRegisterListService.GetUserDetail(Number(bemsValue));
                const apiResult = response?.data || null;

                console.log(apiResult, "apiResult");
                setResult(apiResult);

                if (apiResult) {
                    // ✅ Update form data directly
                    formDataMapRef.current[dataItem.ID] = {
                        ...(formDataMapRef.current[dataItem.ID] || dataItem),
                        NAME: apiResult?.UserName || dataItem.NAME,
                        PHONE: apiResult?.PhoneNo || dataItem.PHONE,
                        EMAIL: apiResult?.Email || dataItem.EMAIL
                    };

                    // optional: also reflect in grid row
                    dataItem.NAME = apiResult?.UserName || dataItem.NAME;
                    dataItem.PHONE = apiResult?.PhoneNo || dataItem.PHONE;
                    dataItem.EMAIL = apiResult?.Email || dataItem.EMAIL;

                    // clear search box after successful fetch
                    setSearchInput((prev) => ({
                        ...prev,
                        [dataItem.ID]: ""
                    }));

                    // force re-render so FocalForm gets updated savedFormData
                    forceRefresh((prev) => prev + 1);

                    props.setDirtyFlag?.(true);
                }
            } catch (error) {
                console.error("Error fetching data:", error);
            }
        },
        [searchInput, props]
    );

    const NameEditableCell: React.ComponentType<GridCellProps> = useCallback((cellProps) => {
        const dataItem = cellProps.dataItem;
        const isExpanded = !!detailExpand[dataItem.ID];
        const showSearchField = isExpanded && !!dataItem.newFlag;

        const bemsValue = searchInput[dataItem.ID] ?? "";

        if (!showSearchField) {
            return (
                <td>
                    <span>{dataItem.NAME || ""}</span>
                </td>
            );
        }

        return (
            <td>
                <BemsSearchInput
                    value={bemsValue}
                    onChange={(value) => {
                        setSearchInput((prev) => ({
                            ...prev,
                            [dataItem.ID]: value
                        }));
                    }}
                    onSearch={() => handleSearch(dataItem)}
                    onEnter={() => handleSearch(dataItem)}
                />
            </td>
        );
    }, [detailExpand, searchInput, handleSearch]);

    const activeCheckbox: React.ComponentType<GridCellProps> = useCallback((cellProps) => {
        const dataItem = cellProps.dataItem;

        const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
            const checked = e.target.checked;

            const updated = {
                ...dataItem,
                ISACTIVE: checked
            };

            cellProps.onChange?.({
                dataIndex: cellProps.dataIndex,
                dataItem: updated,
                field: "ISACTIVE",
                syntheticEvent: e,
                value: checked
            });
        };

        return (
            <td>
                <div style={{ display: "flex", justifyContent: "center" }}>
                    <input type="checkbox" checked={!!dataItem.ISACTIVE} onChange={handleChange} />
                </div>
            </td>
        );
    }, []);

    const setPercentage = (width = 0, percentage = 0, minWidth = 0) => {
        let k_grid_width = document.querySelector("#kgrid-oss-checklistType")?.clientWidth;
        let fixedWidth = totalColumnFixedWidth;
        let dynamicWidth = 0;
        let minScreenWidth = 1250;

        if (k_grid_width) {
            if (k_grid_width <= minScreenWidth) {
                return minWidth;
            } else {
                dynamicWidth = k_grid_width - fixedWidth;
                if (width == 0 && dynamicWidth > 0 && percentage > 0) {
                    const dynamicColumnWidth = Math.round(dynamicWidth * (percentage / 100));
                    return Math.max(minWidth, dynamicColumnWidth);
                } else {
                    return calculatedDynamicColWidth != 0
                        ? minWidth > dynamicWidth - calculatedDynamicColWidth
                            ? minWidth
                            : undefined
                        : undefined;
                }
            }
        }
    };

    useEffect(() => {
        if (props.expandFocalId) {
            setDetailExpand({
                [props.expandFocalId]: true
            });
        }
    }, [props.expandFocalId]);

    useEffect(() => {
        if (props.focalData?.length) {
            const newRow = props.focalData.find((row: any) => row.newFlag);

            if (newRow) {
                setDetailExpand((prev) => ({
                    ...prev,
                    [newRow.ID]: true
                }));
            }
        }
    }, [props.focalData]);

    return (
        <div style={{ height: "calc(100vh - 240px)" }}>
            <Card
                style={{
                    borderLeft: "4px solid #0033A1",
                    marginLeft: "22px",
                    overflow: "hidden",
                    maxHeight: "calc(100vh - 240px)"
                }}
            >
                <AnyGrid
                    ref={gridRefBuilder}
                    id="kgrid-oss-checklistType"
                    className="focal-grid-compact"
                    data={gridData}
                    dataItemKey="ID"
                    scrollable="scrollable"
                    resizable
                    editField={editField}
                    {...props.dataState}
                    onDataStateChange={props.dataStateChange}
                    onItemChange={props.itemChange}
                    columnMenuIcon={filterIcon}
                    detail={DetailComponent}
                    detailExpand={detailExpand}
                >
                    <GridToolbar key="grid-toolbar">
                        <Button
                            className="easalist-marginLeft10"
                            id="createBtn"
                            title="Create New"
                            onClick={props.createFocal}
                            size={"small"}
                            color={"inherit"}
                            variant={"outlined"}
                        >
                            <AddCircleOutlineIcon className="iconClass" />
                            <Typography
                                variant={"button"}
                                sx={{ textTransform: "none", fontSize: "14px" }}
                            >
                                Create New
                            </Typography>
                        </Button>

                        <Box
                            sx={{
                                display: "flex",
                                alignItems: "center",
                                gap: 1.5,
                                position: "absolute",
                                right: 20
                            }}
                        >
                            <Typography
                                variant="body2"
                                sx={{
                                    color: "#253746",
                                    fontWeight: 500,
                                    whiteSpace: "nowrap"
                                }}
                            >
                                Sort Order :
                            </Typography>

                            <FormControl variant="outlined">
                                <Select
                                    id="register-type-select-dropdown"
                                    className="text-normal"
                                    style={{
                                        width: "200px",
                                        height: "32px",
                                        fontSize: "14px",
                                        color: "#253746"
                                    }}
                                    value={props.sortBy || "custom"}
                                    onChange={(e) =>
                                        props.handleSortByChange(
                                            "focal",
                                            e.target.value as "custom" | "asc" | "desc"
                                        )
                                    }
                                >
                                    <MenuItem value="custom">
                                        <SettingsIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                                        Customize
                                    </MenuItem>
                                    <MenuItem value="asc">
                                        <ArrowUpwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                                        Focal Management: Ascending
                                    </MenuItem>
                                    <MenuItem value="desc">
                                        <ArrowDownwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                                        Focal Management : Descending
                                    </MenuItem>
                                </Select>
                            </FormControl>
                        </Box>
                    </GridToolbar>

                    <GridColumn
                        {...props.columnPropsBuilder("NAME")}
                        title="Focal Name"
                        width={setPercentage(undefined, 0, 272)}
                        cells={{ data: NameEditableCell }}
                    />
                    <GridColumn
                        field="PHONE"
                        title="Phone Number"
                        width={setPercentage(undefined, 0, 272)}
                    />
                    <GridColumn
                        field="EMAIL"
                        title="Email"
                        width={setPercentage(undefined, 0, 272)}
                    />
                    <GridColumn title="Active" cells={{ data: activeCheckbox }} width="120px" />
                    <GridColumn title="Focals" cells={{ data: ContactFocals }} width="100px" />
                </AnyGrid>
            </Card>
        </div>
    );
});

export default FocalTable;
