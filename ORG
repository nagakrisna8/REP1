useEffect(() => {
    if (savedFormData) {
        setFormData({
            id: savedFormData.id ?? savedFormData.ID ?? 0,
            name: savedFormData.name ?? savedFormData.NAME ?? "",
            address: savedFormData.address ?? savedFormData.ADDRESS ?? "",
            phone: String(savedFormData.phone ?? savedFormData.PHONE ?? ""),
            email: savedFormData.email ?? savedFormData.EMAIL ?? "",
            position: savedFormData.position ?? savedFormData.DEPARTMENT ?? "",
            title: savedFormData.title ?? savedFormData.TITLE ?? "",
            isActive: savedFormData.isActive ?? savedFormData.ISACTIVE ?? false
        });
    }
}, [savedFormData]);
