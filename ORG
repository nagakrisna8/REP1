import "../AdminTable.scss";
import React, { memo, useCallback, useEffect, useRef, useState } from "react";
import { OrganizationTableData, SortByData } from "../AdminModal";
import { State, process } from "@progress/kendo-data-query";
import {
  Grid as DataGrid,
  GridCellProps,
  GridColumn,
  GridColumnMenuFilter,
  GridColumnMenuProps,
  GridDataStateChangeEvent,
  GridItemChangeEvent,
  GridToolbar
} from "@progress/kendo-react-grid";

import {
  Box,
  Button,
  Card,
  FormControl,
  MenuItem,
  Select,
  TextField,
  Typography
} from "@mui/material";

import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import SettingsIcon from "@mui/icons-material/Settings";
import ArrowUpwardIcon from "@mui/icons-material/ArrowUpward";
import ArrowDownwardIcon from "@mui/icons-material/ArrowDownward";
import SortIcon from "@mui/icons-material/Sort";
import GroupIcon from "@mui/icons-material/Group";
import ArrowDropDownIcon from "@mui/icons-material/ArrowDropDown";
import ArrowDropUpIcon from "@mui/icons-material/ArrowDropUp";

import { filterIcon } from "@progress/kendo-svg-icons";
import FocalList from "./FocalList";

const editField = "inEdit";
const SELECTED_FIELD = "selected";
const AnyGrid = DataGrid as any;

const GridFilterMenuWithoutSort = (props: GridColumnMenuProps) => (
  <div>
    <GridColumnMenuFilter {...props} expanded />
  </div>
);
interface OrganizationTypeTableProps {
  KEY: string;
  columnPropsBuilder: (field: any) => { field: any; columnMenu: (props: any) => JSX.Element; headerClassName: string };
  organizationData: OrganizationTableData[];
  dataState: State;
  dataStateChange: (event: GridDataStateChangeEvent) => void;
  itemChange: (event: GridItemChangeEvent) => void;
  createOrganization: () => void;
  saveOrganization: () => void;
  onCreateFocal: () => void;
  dragStart: (dataItem: OrganizationTableData) => void;
  reorder: (dataItem: OrganizationTableData) => void;
  sortBy: "custom" | "asc" | "desc" | undefined;
  handleSortByChange: (key: keyof SortByData, value: "custom" | "asc" | "desc", setScreenDirty?: boolean) => void;
}

const OrganizationTable: React.FC<any> = memo((props) => {

  const gridRefBuilder = useRef<any>(null);
  const [calculatedDynamicColWidth, setCalculatedDynamicColWidth] = useState(0);
  const [totalColumnFixedWidth, setTotalColumnFixedWidth] = useState(0);

  // expansion state
  const [detailExpand, setDetailExpand] = React.useState<{ [key: number]: boolean }>({});

  const expandChange = (dataItem: any) => {
    const key = dataItem.ORGANIZATIONID;
    setDetailExpand(prev => {
      const isCurrentlyOpen = prev[key];
      if (isCurrentlyOpen) {
        return {};
      }
      return { [key]: true };
    });

  };
  const gridData = process(props.organizationData, {
    sort: props.dataState.sort,
    filter: props.dataState.filter,
    take: undefined,
    skip: undefined
  }).data;


  const OrganizationCell: React.ComponentType<GridCellProps> = useCallback(
    (cellProps) => {

      const field = cellProps.field || "";
      const value = cellProps.dataItem[field] ?? "";

      const handleChange = (e: any) => {

        const updated = { ...cellProps.dataItem };
        updated[field] = e.target.value;

        cellProps.onChange?.({
          dataIndex: cellProps.dataIndex,
          dataItem: updated,
          field,
          syntheticEvent: e,
          value: e.target.value
        });
      };

      return (
        <td>
          <TextField fullWidth value={value} onChange={handleChange} />
        </td>
      );
    },
    []
  );

  const DragCell: React.ComponentType<GridCellProps> = (dragcellprops) => (
    <td
      onDragOver={(e) => {
        e.preventDefault();
        props.reorder(dragcellprops.dataItem);
      }}
    >
      <span
        draggable
        style={{
          cursor: "move",
          display: "flex",
          //justifyContent: "center"
        }}
        onDragStart={() => props.dragStart(dragcellprops.dataItem)}
      >
        <SortIcon />
      </span>
    </td>
  );

  // Custom arrow column
  const ContactFocals: React.ComponentType<GridCellProps> = (cellProps) => {

    const expanded = detailExpand[cellProps.dataItem.ORGANIZATIONID];

    const toggle = (e: React.MouseEvent) => {
      e.stopPropagation();
      expandChange(cellProps.dataItem);
    };

    return (
      <td>
        <div style={{ display: "flex", justifyContent: 'center', alignItems: "center", gap: 6, }}>
          <GroupIcon />

          <span
            onClick={toggle}
            style={{ cursor: "pointer", display: "flex" }}
          >
            {expanded ? <ArrowDropUpIcon /> : <ArrowDropDownIcon />}
          </span>
        </div>
      </td>
    );
  };

  const DetailComponent = (detailProps: any) => {

    const orgName = detailProps.dataItem.ORGANIZATIONID;

    return (
      <div>
        <FocalList orgName={orgName} orgType={props.selectedOrgId} onCreateFocal={props.onCreateFocal} />
      </div>
    );
  };
  const activeCheckbox: React.ComponentType<GridCellProps> = (cellProps) => {
    const dataItem = cellProps.dataItem;

    const handleChange = (e: any) => {
      const updated = {
        ...dataItem,
        ISACTIVE: e.target.checked
      };

      cellProps.onChange?.({
        dataIndex: cellProps.dataIndex,
        dataItem: updated,
        field: cellProps.field,
        syntheticEvent: {} as React.SyntheticEvent,
        value: e.target.checked
      });
    };

    return (
      <td>
        <div style={{ display: "flex", justifyContent: "center" }}>
          <input
            type="checkbox"
            checked={dataItem.ISACTIVE}
            onChange={handleChange}
          />
        </div>
      </td>
    );
  };
  const setPercentage = (width = 0, percentage = 0, minWidth = 0) => {
    let k_grid_width = document.querySelector("#kgrid-oss-checklistType_org")?.clientWidth;
    let fixedWidth = totalColumnFixedWidth;
    let dynamicWidth = 0;
    let minScreenWidth = 1250;
    let maxScreenWidth;
    if (k_grid_width) {
      if (k_grid_width <= minScreenWidth) {
        return minWidth;
      }
      else {
        dynamicWidth = k_grid_width - fixedWidth;
        if (width == 0 && dynamicWidth > 0 && percentage > 0) {
          const dynamicColumnWidth = Math.round(dynamicWidth * (percentage / 100));
          return Math.max(minWidth, dynamicColumnWidth);
        }
        else {
          return calculatedDynamicColWidth != 0 ? minWidth > (dynamicWidth - calculatedDynamicColWidth) ? minWidth : undefined : undefined
        }
      }
    }
  }
  return (
    <div
    //  style={{ height: "calc(100vh - 240px)" , overflow:'hidden'}}
    >
      <Card
        style={{
          borderLeft: "4px solid #0033A1",
          marginLeft: "22px",
          overflow: "hidden",
        }}
      >
        <AnyGrid
          ref={gridRefBuilder}
          id="kgrid-oss-checklistType_org"
          data={gridData}
          dataItemKey="ORGANIZATIONID"
          resizable
          editField={editField}
          // {...props.dataState}
          selectedField={SELECTED_FIELD}
          onDataStateChange={props.dataStateChange}
          onItemChange={props.itemChange}
          columnMenuIcon={filterIcon}
          detail={DetailComponent}
          detailExpand={detailExpand}
        >

          <GridToolbar key="grid-toolbar">
            {
              <Button
                className="easalist-marginLeft10"
                id="createBtn"
                title="Create New"
                onClick={props.createOrganization}
                size={"small"}
                color={"inherit"}
                variant={"outlined"}

              >
                <AddCircleOutlineIcon className="iconClass" />
                <Typography
                  variant={"button"}
                  sx={{ textTransform: "none", fontSize: "14px" }}
                >
                  Create New
                </Typography>
              </Button>
            }

            {
              < Button
                className="easalist-marginLeft10"
                id="saveBtn"
                title="Save"
                onClick={props.saveOrganization}
                variant={"outlined"}
                size={"small"}
                color={"inherit"}
              >
                <Typography
                  variant={"button"}
                  sx={{ textTransform: "none", fontSize: "14px" }}
                >
                  Save
                </Typography>
              </Button >
            }
            {
              <Box
                sx={{
                  display: "flex",
                  alignItems: "center",
                  gap: 1.5,
                  position: "absolute",
                  right: 20,
                }}
              >
                <Typography
                  variant="body2"
                  sx={{
                    color: "#253746",
                    fontWeight: 500,
                    whiteSpace: "nowrap",
                  }}
                >
                  Sort Order :
                </Typography>
                <FormControl variant="outlined">
                  <Select
                    id="register-type-select-dropdown"
                    className="text-normal"
                    style={{
                      width: "200px",
                      height: "32px",
                      fontSize: "14px",
                      color: "#253746",
                    }}
                    value={props.sortBy || "custom"}
                    onChange={(e) =>
                      props.handleSortByChange(
                        "organization",
                        e.target.value as "custom" | "asc" | "desc"
                      )
                    }
                  >
                    <MenuItem value="custom">
                      <SettingsIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                      Customize
                    </MenuItem>
                    <MenuItem value="asc">
                      <ArrowUpwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                      Organization : Ascending
                    </MenuItem>
                    <MenuItem value="desc">
                      <ArrowDownwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                      Organization : Descending
                    </MenuItem>
                  </Select>
                </FormControl>
              </Box>
            }
          </GridToolbar >
          <GridColumn title="Sort" cells={{ data: DragCell }} width="70px" />
          <GridColumn
            {...props.columnPropsBuilder("ORGANIZATIONNAME")}
            title="Organization Name"
            cells={{ data: OrganizationCell }}
            width={setPercentage(undefined, 0, 272)}
          />
          <GridColumn
            {...props.columnPropsBuilder("ORGANIZATIONDESCRIPTION")}
            title="Description"
            cells={{ data: OrganizationCell }}
            width={setPercentage(undefined, 0, 272)}
          />
          <GridColumn
            title="Active"
            cells={{ data: activeCheckbox }}
            width="90px"
          />
          <GridColumn
            {...props.columnPropsBuilder("NOTES")}
            title="Notes"
            cells={{ data: OrganizationCell }}
            width={setPercentage(undefined, 0, 472)}
          />
          <GridColumn
            title="Contact Focals"
            cells={{ data: ContactFocals }}
            width="150px"
          />
        </AnyGrid>
      </Card>
    </div>
  );
});

export default OrganizationTable;
