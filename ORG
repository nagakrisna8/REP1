let isDuplicate = false;

if (formData.email && formData.email.trim() !== "") {
    // Check duplicate by EMAIL
    isDuplicate = focalList?.some(
        (item: FocalData) =>
            item.EMAIL?.trim().toLowerCase() === formData.email.trim().toLowerCase() &&
            item.ID !== formData.id
    );
} else {
    // If email not provided → check duplicate by NAME
    isDuplicate = focalList?.some(
        (item: FocalData) =>
            item.NAME?.trim().toLowerCase() === formData.name.trim().toLowerCase() &&
            item.ID !== formData.id
    );
}

if (isDuplicate) {
    dispatch(showSnackbar({
        snackbarOpen: true,
        snackbarType: "error",
        snackbarMessage: formData.email
            ? "Email must be unique."
            : "Focal Name must be unique."
    }));
    return;
}
