import SupportingInsertPopupData from "../../../compliance-showing/supporting-insert-popup-data-grid/SupportingInsertPopupData";
import SuppInsertPopupDataService from "../../../compliance-showing/supporting-insert-popup-data-grid/SuppInsertPopupDataService";
import { error } from "console";
import PathConstants from "../../../../../../../routes/PathConstants";
import ConfigureReferencesService from "../../ConfigureReferencesService";
import AddRevisionPopupService from "../../../dynamic-tabs/add-revision-popup/AddRevisionPopupService";
import UserToken from "../../../../../../../utils/UserToken";
import { fetchStart, fetchSuccess } from '../../../compliance-showing/supporting-data-grid/SupportingDataReferenceContentSlice'
import CommonFunction from "../../../../../../../utils/CommonFunction";

var configRefDocDetails: RefDocGridDetails[] = [];

interface ConfigRefDropdownData {
    RefDocId: number;
    DocumentNumber: string;
    RevLevel: string;
    DocumentTitle: string;
};

const initialBoeingRefGridData = {
    DocumentNumber: "",
    DocumentTitle: "",
    Notes: "",
    RefSequence: "",
    RefDocId: 0,
    RevLevel: "",
    RptId: 0,
    Source: "",
    SupportingProjectidSdtno: "",
    TableCode: "",
    BoeingRefGridRowCommentCnt: 0,
    BoeingRefGridRowUnResolvedCommentCnt: 0,
    ItemStatus: "",
}

const initialSelectedDropDownData = {
    DocumentNumber: "",
    DocumentTitle: "",
    RefDocId: 0,
    RevLevel: "",
}

const excludeToolbarItemArray = [ToolsEnum.InsertImage, ToolsEnum.renderEquationTool];

const KendoEditorSection = ({ editorKey, getCommentCount, handleOpenHistoryPopup, editorCommentsDtl, reportLevelTagList, refreshAllEditor, openHistoryPopup, handleCloseHistoryPopup, label, columnName, targetContent, content, onChange, reportId, props, tabName, tableCode, saveTabDetails, excludeToolbarItemArray, rowId }) => {
    let updatedSectionTitle = "Supporting Data Grid" + ", " + targetContent.replace(/([A-Z])/g, ' $1').trim();
    const comments = editorCommentsDtl.filter(comment => comment.ColumnName === columnName);
    const commentStatus = comments?.some(comment => comment.CommentStatus === "0") ? "error" : "success";

    return (
        <Grid container spacing={3} direction={"row"} style={{ margin: '0px', width: '100%' }}>
            <Grid item xs={12} className='grid-item-spacing' style={{ display: 'flex' }}>
                <Grid item md={12}>
                    <Grid md={12} style={{ display: 'flex' }}>
                        <label>{label}</label>
                    </Grid>
                    <Grid md={12} style={{ display: 'flex' }}>
                        <Grid md={11} className="editSupportingContentLeft">
                            <Grid>
                                <div className={`editorContentId-${rowId ? rowId : 'default'}`}>
                                    <KendoEditor
                                        controlName={columnName}
                                        selectedRowId={0}
                                        contentID={0}
                                        currentTabComments={comments}
                                        reportLevelTagList={reportLevelTagList}
                                        IsBadgeIconClick={false}
                                        IsNonDynamicTab={true}
                                        IsError={false}
                                        headerData={props.headerData}
                                        tools={"PARAGRAPH"}
                                        content={content}
                                        key={editorKey}
                                        onEditorChange={(event) => { onChange && onChange(event, targetContent, `${event.html}`, content) }}
                                        item={null}
                                        contentKey={"ParagraphContent"}
                                        updateTotalCompGridCommentCount={null}
                                        totalComment={0}
                                        sendDataToRootParent={null}
                                        reportId={reportId}
                                        loadContentCommenttdata={null}
                                        refreshAllEditor={refreshAllEditor}
                                        sectionTitle={updatedSectionTitle}
                                        openHistoryPopup={openHistoryPopup}
                                        handleCloseHistoryPopup={handleCloseHistoryPopup}
                                        tabName={tabName}
                                        tableCode={tableCode}
                                        saveTabDetails={saveTabDetails}
                                        excludeToolbarItemArray={excludeToolbarItemArray}
                                    />
                                </div>
                            </Grid>
                        </Grid>
                        <Grid item md={1} className="manageSupportingComment">
                            <Badge id="badge2" anchorOrigin={{ vertical: 'top', horizontal: 'right' }} style={{ color: '#737373' }} badgeContent={getCommentCount(columnName)} color={commentStatus}>
                                <IconButton onClick={() => handleOpenHistoryPopup(columnName, comments[0]?.ContentID || 0, false)}>
                                    <SpeakerNotesOutlinedIcon />
                                </IconButton>
                            </Badge>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    )
};

const ManageReferenceData = React.forwardRef<any, any>((props, ref) => {
    const userToken = new UserToken();
    const userBemsId = userToken.getUserBemsId();
    //const [getRowWiseSupData, setRowWiseSupData] = useState<SupportingRowWiseDetails | null>(null);
    const [getRowWiseRefData, setRowWiseRefData] = useState<RefDocGridDetails | null>(null);
    const [selectedDocNumberValue, setSelectedDocNumberValue] = useState<ConfigRefDropdownData | null>(null);
    const [getConfigDropDownData, setConfigDropdownData] = useState<ConfigRefDropdownData[]>([]);
    const [getRefDocDetails, setRefDocDetails] = useState<RefDocGridDetails[]>([]);
    // const [refGridDataLength,setRefGridDataLength] = useState<Number>(0);
    const [isTabDirty, setIsTabDirty] = useState<boolean>(false);
    var { reportId = "", tabIndex = "" } = useParams();
    const reportIdParam = Number(reportId);
    const dispatch = useDispatch();
    const navigate = useNavigate();
    const storageService = new StorageService;
    const selectedReportTemplate = storageService.getApplicationDataByKey(
        `${EnvDetail.ParentAppName}-${EnvDetail.AppName}`,
        'SelectedEasaReportType'
    );
    const showReasonDropdown = selectedReportTemplate === ReportType.DQN;
    const [searchDocId] = useSearchParams();
    const getRefGridId = searchDocId.get('edit');
    // comment functionality states
    const [editorCommentsDtl, setEditorCommentsDtl] = useState<any[]>([]);
    const [reportLevelTagList, setReportLevelTagList] = useState<TagDetails[]>([]);
    const [controlCommentCount, setControlCommentCount] = useState<ControlCommentCount[]>([]);
    const [openHistoryPopup, setOpenHistoryPopup] = useState<boolean>(false);
    const [contentID, setContentID] = useState<number>(0);
    const [controlName, setControlName] = useState<any>("");
    const [editorKey, setEditorKey] = useState<number>(0);
    const [addNewComment, setIsNewComment] = useState(false);
    const [isControlLevelComment, setIsControlLevelComment] = useState<boolean>(false);
    const [openSupportingInsertPopup, setOpenSupportingInsertPopup] = useState(false);  // handling insert supporting popup
    const [existData, setExistData] = useState<RefDocGridDetails | null>(null);
    const openSupInsertPopup = (existData) => {
        setOpenSupportingInsertPopup(true);
        setExistData(existData);
    };
    const tempReferencesRef = useRef(getRowWiseRefData);
    const [getPurposeList, setPurposeList] = useState<GetRegulationPurposeData[]>([]);
    const [statusList, setStatusList] = useState<GetStatus[]>([]);
    const [selectedStatus, setSelectedStatus] = useState<GetStatus | null>(null);
    const [selectedValue, setSelectedValue] = useState<GetRegulationPurposeData | null>(null);

    const [getReasonList, setReasonList] = useState<GetReasonCodeData[]>([]);
    const [selectedReason, setSelectedReason] = useState<GetReasonCodeData | null>(null);

    const handleRowWiseRefDataChange = (supportingData) => {
        const { DocumentNumber, RevLevel, Source, DocumentTitle, Notes } = supportingData;
        var onChangeVal: Partial<SupportingRowWiseDetails> = {};
        onChangeVal.DocumentNumber = DocumentNumber;
        onChangeVal.RevLevel = RevLevel;
        onChangeVal.Source = Source;
        if (Notes !== null && Notes !== undefined && Notes !== '') {
            onChangeVal.Notes = Notes;
        }
        if (DocumentTitle !== null && DocumentTitle !== undefined && DocumentTitle !== '') {
            onChangeVal.DocumentTitle = DocumentTitle;
        }
        setRowWiseRefData((prev) => {
            if (prev) {
                return {
                    ...prev,
                    ...onChangeVal
                };
            }
            return null;
        });

        setEditorKey(prev => prev + 1);
        storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, true);
        setIsTabDirty(true);
    };

    const closeSupInsertPopup = (checkIsDataAdded, insertSupportingdata) => {
        if (checkIsDataAdded) {
            handleRowWiseRefDataChange(insertSupportingdata);
        };
        setOpenSupportingInsertPopup(false);
    };

    const isPendingWithUser = () => {
        let currentUserBemsId = AuthorizationService.getUserBemsId();
        const isUserDataExist = props.headerData?.PendingWithBemsId?.filter(item => {
            return item == currentUserBemsId;
        });
        if (isUserDataExist && isUserDataExist.length > 0 && props.headerData?.RELEASE_DATE == null)
            return true;
        return false;
    };

    React.useEffect(() => {
        //const scrollPosition = window['rightPaneScrollPosition'] || "0";
        // const scrollableDiv: any = document.querySelector('#left-custom-box');
        // scrollableDiv.scrollTo(0, parseInt(scrollPosition, 10));
        //window.scroll(0, scrollPosition);
    });

    const bookmarkNavigation = () => {
        const getBookmarkLinkId = new StorageService().getApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, 'bookmarkLinkId');
        if (getBookmarkLinkId != "" && getBookmarkLinkId?.split("-")[0] > 0 && getRowWiseRefData && getRowWiseRefData?.RefDocId == getBookmarkLinkId?.split("-")[0]) {
            const getBookmarkRowId = getBookmarkLinkId.split("-")[0];
            const getBookmarkAnchorId = getBookmarkLinkId.split("-")[1];
            let getBookMarkDestinationByClassName = document.querySelectorAll('[class^="bookmark_destination-"], [class*=" bookmark_destination-"]');
            for (let i = 0; i < getBookMarkDestinationByClassName.length; i++) {
                const anchorElement = getBookMarkDestinationByClassName[i];
                let getElementContentId = anchorElement.className?.split("-")[3];
                let getElementBKId = anchorElement.id;
                if (getElementContentId == getBookmarkRowId && getElementBKId == getBookmarkAnchorId) {
                    const topOffset = (anchorElement as HTMLElement).getBoundingClientRect().top + window.pageYOffset;
                    window.scrollTo({ top: topOffset - 150, behavior: 'smooth' });
                    (anchorElement as HTMLElement).style.border = '2px solid #1976d2';
                    setTimeout(() => {
                        (anchorElement as HTMLElement).style.border = 'none';
                    }, 5000);
                };
            };
        }
    };

    useEffect(() => {
        tempReferencesRef.current = getRowWiseRefData;
        bookmarkNavigation();   // function calling for bookmark navigation
    }, [getRowWiseRefData]);

    const handleOpenHistoryPopup = (controlName, contentID, isInputControl) => {
        const comments = editorCommentsDtl.filter(comment => comment.ColumnName === controlName);
        setContentID(contentID);
        setOpenHistoryPopup(true);
        setControlName(controlName);
        if (isPendingWithUser()) {
            setIsNewComment(true);
        }
        if (isInputControl) {
            setIsControlLevelComment(true);
        }
        setContentID(comments[0]?.ContentID || 0);
    };

    const refreshAllEditor = () => {
        fetchData(true);
    };

    const handleCloseHistoryPopup = (isPopupDirty) => {
        setOpenHistoryPopup(false);
        setIsNewComment(false);
        setIsTabDirty(false);
        storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, false);
        if (isPopupDirty) {
            refreshAllEditor();
        }
    };

    const handleCommentStatus = (controlName) => {
        const comments = editorCommentsDtl.filter(comment => comment.ColumnName === controlName);
        const commentStatus = comments?.some(comment => comment.CommentStatus === "0") ? "error" : "success";
        return commentStatus;
    }

    const updateAddNewComment = (value) => {
        setIsNewComment(value);
    };

    const getCommentCount = (controlName) => {
        const control = controlCommentCount.filter(item => item.ControlName === controlName);
        return control.length > 0 ? control[0].CommentCnt : 0;
    };

    const fetchData = async (highlightTabAndHdr) => {

        const response = await ConfigureReferencesService.GetReferenceDataByRefDocId(Number(getRefGridId));
        if (response && response.data) {

            let configRefDtl = {
                RefDocId: Number(getRefGridId),
                RptId: reportIdParam,
                TableCode: Number(getRefGridId) === 0 ? props.selectedConfigData.TableCode : response.data[0].TableCode,
                ReqCompId: 0,
            } as ConfigRefDtl;

            let controlDtl = {
                ControlId: 0,
                RptId: reportIdParam,
                RowId: Number(getRefGridId),
                ScreenName: Number(getRefGridId) === 0 ? props.selectedConfigData.TableCode : response.data[0].TableCode,
                FieldName: ""
            } as ControlsDtls;
            const key = `${configRefDtl.TableCode ?? ""}`;
            dispatch(fetchStart({ key }));
            const [getRefRowWiseDtl, configRefDataResult, getCofigRefComment, getConfigRefCmtCount, reportLevelTagDetailRes, regPurposeData, reasonMasterData, easaStatusList] = await Promise.all([
                ReferenceDataGridService.getReferenceDocumentDetails(configRefDtl),
                ReferenceDataGridService.getReferenceDocumentDetails({ ...configRefDtl, RefDocId: 0 }),
                ManageReferenceDataService.GetControlCommentsData(controlDtl, true),
                ManageReferenceDataService.GetControlCommentCount(controlDtl),
                dynamicTabsService.getReportLevelTagDetails(reportIdParam),
                SuppInsertPopupDataService.GetRegulationPurposeMasterData(),
                ManageReferenceDataService.GetReasonCodeData(),
                ManageReferenceDataService.GetEasaStatus()
            ]);
            const list = configRefDataResult.data.RefDetailsList ?? [];
            dispatch(fetchSuccess({ key, data: list }));
            if (regPurposeData && regPurposeData.data.length > 0) {
                const getInitialPurposeData = regPurposeData.data.filter((list) => list.MasterValue === response.data[0]?.Purpose);
                if (getInitialPurposeData.length > 0) {
                    setSelectedValue(getInitialPurposeData[0]);
                }
                setPurposeList(regPurposeData.data);
            }
            if (reasonMasterData && reasonMasterData.data && reasonMasterData.data.length > 0) {
                setReasonList(reasonMasterData.data);
                if (showReasonDropdown && getRefRowWiseDtl.data?.RefDetailsList && Number(getRefGridId) != 0) {
                    const initial = reasonMasterData.data.find(r => r.ReasonCode === getRefRowWiseDtl.data.RefDetailsList[0].ReasonCode);
                    if (initial) setSelectedReason(initial);
                }
            }
            if (getRefRowWiseDtl.data && getRefRowWiseDtl.data.RefDetailsList && Number(getRefGridId) != 0) {   // api for getting row wise config ref data dynamically
                setRowWiseRefData(getRefRowWiseDtl.data.RefDetailsList[0]);
            }
            if (configRefDataResult.data && configRefDataResult.data.RefDetailsList) {
                configRefDocDetails = configRefDataResult.data.RefDetailsList
                var resultDropDownData: ConfigRefDropdownData[] = configRefDocDetails.map((item) => ({
                    RefDocId: item.RefDocId,
                    DocumentNumber: item.DocumentNumber,
                    RevLevel: item.RevLevel,
                    DocumentTitle: item.DocumentTitle
                }));
                if (resultDropDownData.length > 0 && getRefRowWiseDtl.data?.RefDetailsList && Number(getRefGridId) != 0) {
                    const selectedOption = resultDropDownData.find(item => item.DocumentNumber === getRefRowWiseDtl.data.RefDetailsList[0].DocumentNumber);
                    setSelectedDocNumberValue(selectedOption || null);
                }
                setRefDocDetails(getRefRowWiseDtl.data?.RefDetailsList)
                // setRefGridDataLength(resultDropDownData.length);
                setConfigDropdownData(resultDropDownData);
            }
            if (easaStatusList.data) {
                const getInitialStatus = easaStatusList.data.filter((list) => list.StatusId === response.data[0]?.EASAStatusId);
                if (getInitialStatus != null) {
                    setSelectedStatus(getInitialStatus[0]);
                }
                setStatusList(easaStatusList.data);
            };
            if (getCofigRefComment.data) {
                setEditorCommentsDtl(getCofigRefComment.data);
            };
            if (getConfigRefCmtCount.data) {
                setControlCommentCount(getConfigRefCmtCount.data);
            }
            if (reportLevelTagDetailRes.data) {
                setReportLevelTagList(reportLevelTagDetailRes.data);
            }
            setEditorKey(prev => prev + 1);
            // Method to highlight Header Compliance Button
            if (highlightTabAndHdr)
                getUnresolvedCommentCountForHeaderBtn();
        }
    };

    const getUnresolvedCommentCountForHeaderBtn = () => {
        dynamicTabsService.getUnresolvedCommentCountForHeaderBtn(parseInt(reportId)).then(result => {
            // Publish to update color in case of unresolve comment
            let dataToShare = {
                Action: 'UpdateColorData',
                Detail: {
                    CountResult: result.data
                }
            };
            PubSub.publish(PubSubEvent.HIGHLIGHT_HEADER_BUTTON, dataToShare);
        });
        let detailsToShare = {
            Action: 'UpdateColorData',
            Detail: {
                TotalUnresolvedCommentCount: 0,
                tabId: tabIndex
            }
        };
        PubSub.publish(PubSubEvent.UPDATE_TAB_COLOR, detailsToShare);
    }

    useEffect(() => {
        if (Number(getRefGridId) > 0) {
            fetchData(false);
        } else if (getRefGridId === "0") {
            setRowWiseRefData(initialBoeingRefGridData);
            setSelectedDocNumberValue(initialSelectedDropDownData);
            fetchData(false);
        };
    }, [getRefGridId]);

    const handleDocumentChange = (selectedOption: ConfigRefDropdownData | null) => {
        if (!selectedOption) {
            setSelectedDocNumberValue(null);
            setRowWiseRefData(null);
            tempReferencesRef.current = null;
            return;
        }
        const refRowId = selectedOption.RefDocId;
        if (isTabDirty) {
            userDefinedConfirm({ message: `There are unsaved changes in the current session. Do you want to proceed without saving?`, okBtnText: "Yes", cancelBtnText: "Cancel" }).then(
                ({ button, input }) => {
                    setRowWiseRefData(null);
                    tempReferencesRef.current = null;
                    setSelectedDocNumberValue(selectedOption);
                    props.showManageSection(refRowId);
                    setIsTabDirty(false);
                    storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, false);
                },
                () => {
                    return;
                }
            );
        } else {
            setSelectedDocNumberValue(selectedOption);
            setRowWiseRefData(null);
            tempReferencesRef.current = null;
            props.showManageSection(refRowId);
        }
    };

    const isActiveSectionDirty = async () => {
        return isTabDirty;
    };


    useImperativeHandle(ref, () => ({ saveActiveSectionDetails, isActiveSectionDirty }));

    const numberToAlphabet = (num) => {
        let result = "";
        while (num > 0) {
            num--; // Adjust for 0-based index
            result = String.fromCharCode((num % 26) + 65) + result;
            num = Math.floor(num / 26);
        }
        return result;
    };

    const handleRefSequence = (refSequenceNo) => {
        if (props.selectedConfigData.SupportingFlag === "N") {
            if (getRefGridId === "0") {
                let updatedSeq = getRefDocDetails.length + 1;
                if (props && props?.selectedConfigData?.SequenceStartWith?.includes('.')) {
                    return props?.selectedConfigData?.SequenceStartWith?.replace('.1', `.${updatedSeq}`);
                } else {
                    return numberToAlphabet(updatedSeq).toLowerCase();
                }
            } else {
                return refSequenceNo;
            };
        } else {
            return refSequenceNo;
        }
    };

    const InsertContentLogDetails = async (response) => {
        let tempRevisionDataList: RevisionListDetails[] = [];
        tempRevisionDataList.push({
            ReportId: reportIdParam,
            Description: response.DocumentNumber,
            OperationType: OperationType.ADD,
            CreatedBy: 0,
            TabId: parseInt(tabIndex),
            TabTitle: "",
            AuthorComment: response.DocumentNumber,
            TabSectionId: 0,
            ContentId: 0,
            SecIndexValue: "",
            ContIndexValue: "",
            ModifiedBy: 0,
            TabSectionName: response.TableCode,
            ContentTitleName: response.TableCode,
            ActualTabTitle: "",
        });
        await AddRevisionPopupService.InsertContentLogDetails(tempRevisionDataList).then((res) => {
        }).catch((error) => { });
    };

    const saveActiveSectionDetails = async () => {
        const dataToSave = tempReferencesRef.current;
        if (getRowWiseRefData && dataToSave) {
            if ((!getRowWiseRefData.DocumentNumber || !getRowWiseRefData.RevLevel) && props.selectedConfigData.SupportingFlag === "N") {
                dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "error", snackbarMessage: "Please fill the required fields Document Number and Rev level.", }));
                return;
            }
            else {
                try {
                    let checkIsDocNumberDuplicate = getConfigDropDownData.filter(doc => doc.DocumentNumber === getRowWiseRefData.DocumentNumber).length > 0;
                    if (checkIsDocNumberDuplicate && props.selectedConfigData.SupportingFlag === "N" && selectedDocNumberValue && selectedDocNumberValue?.DocumentNumber !== getRowWiseRefData.DocumentNumber) {
                        dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "error", snackbarMessage: "Document Number can be not duplicate.", }));
                        return;
                    } else {
                        let InsertRefCheckItemsDetails: ConfigRefDocDetails = {} as ConfigRefDocDetails;
                        InsertRefCheckItemsDetails.DocumentNumber = getRowWiseRefData.DocumentNumber;
                        InsertRefCheckItemsDetails.Notes = dataToSave.Notes;
                        InsertRefCheckItemsDetails.Source = getRowWiseRefData.Source;
                        InsertRefCheckItemsDetails.DocumentTitle = dataToSave.DocumentTitle;
                        InsertRefCheckItemsDetails.ProjectNumber = Number(getRefGridId) != 0 ? getRowWiseRefData.SupportingProjectidSdtno : "";
                        InsertRefCheckItemsDetails.SelectedSource = getRowWiseRefData.Source;
                        InsertRefCheckItemsDetails.RefDocId = Number(getRefGridId) != 0 ? getRowWiseRefData.RefDocId : Number(getRefGridId);
                        InsertRefCheckItemsDetails.RevLevel = getRowWiseRefData.RevLevel;
                        InsertRefCheckItemsDetails.RptId = Number(getRefGridId) != 0 ? getRowWiseRefData.RptId : reportIdParam;
                        InsertRefCheckItemsDetails.ItemStatus = Number(getRefGridId) != 0 ? OperationType.UPDATE : OperationType.ADD;
                        // Do create RefSeq, if its already present
                        if (!dataToSave.RefSequence) {
                            const suffixNum = getConfigDropDownData.length > 0 ? getConfigDropDownData.length + 1 : 1;
                            InsertRefCheckItemsDetails.RefSequence = suffixNum.toString();
                        } else {
                            InsertRefCheckItemsDetails.RefSequence = dataToSave.RefSequence.split(".")[1];
                        }
                        InsertRefCheckItemsDetails.TableCode = Number(getRefGridId) != 0 ? getRowWiseRefData.TableCode : props.selectedConfigData.TableCode;
                        InsertRefCheckItemsDetails.CommentRedFlag = "";
                        InsertRefCheckItemsDetails.EASAStatusId = Number(selectedStatus?.StatusId);
                        InsertRefCheckItemsDetails.SupportingDataGridRowCommentCnt = 0;
                        InsertRefCheckItemsDetails.SupportingDataGridRowUnResolvedCommentCnt = 0;
                        InsertRefCheckItemsDetails.Purpose = (Number(getRefGridId) != 0 && getRowWiseRefData.Purpose != "") ? getRowWiseRefData.Purpose : "";
                        InsertRefCheckItemsDetails.SourceId = (Number(getRefGridId) != 0 && getRowWiseRefData.SourceId != null) ? getRowWiseRefData.SourceId : 0;
                        InsertRefCheckItemsDetails.ReasonCode = (Number(getRefGridId) != 0 && getRowWiseRefData.ReasonCode != null) ? getRowWiseRefData.ReasonCode : "";
                        SuppInsertPopupDataService.UpsertReferenceDataByRowId([InsertRefCheckItemsDetails]).then((res) => {
                            dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "success", snackbarMessage: "Data Saved successfully." }));
                            storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, false);
                            setIsTabDirty(false);
                            fetchData(false);
                            if (props.selectedConfigData.SupportingFlag === "N" && Number(getRefGridId) === 0 && res && res.data.length > 0) {
                                let newRefDocId = Number(res.data[0].RefDocId);
                                navigate(`${PathConstants.CONFIGURE_REFERENCES.replace(":reportId", reportId).replace(FixedTabTitle.CONFIGURE_REFERENCES_TAB_INDEX, `${FixedTabTitle.CONFIGURE_REFERENCES_TAB_INDEX}?edit=${newRefDocId}`)}`);
                            };
                            //If revision then need to add in Description of chnge
                            if (props.headerData?.REVISION && props.headerData.REVISION.trim() !== "" && props.headerData.PARENT_RPT_ID != null && props.headerData.PARENT_RPT_ID > 0 && res.data[0].ItemStatus == OperationType.ADD) {
                                InsertContentLogDetails(res.data[0]);
                            };
                        })
                    }
                } catch (error) {
                    console.log('Error occurred while saving Reference Documents.', error);
                }
            };
        };
    };

    const isCurrentUserAuthor = () => {
