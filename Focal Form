const navigateToCSRSearchPage = (rptId: number) => {
            const storageServiceTemp = new StorageService();
            const projectRegisterId = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-easaActiveSubMenu`, 'easamyworkspaceprojectid');
            const groupId = 19;
            const templateId = 2;
            const templateName = "Compliance Checklist";
            console.log(projectRegisterId, 'projectRegisterId');
            let dataToShare = {
                Action: 'CCL_CSR_CCN_Navigation',
                Detail: {   
                    projectRegisterId,
                    groupId,              
                    templateId,
                    templateName,
                    reportId: rptId,
                }
            };
            let appDataEvent = new ShellEventRegister().getShellEvent();
            appDataEvent[`${EnvDetail.ParentAppName}_${EnvDetail.AppName}_EVENT_DATA`] = dataToShare;
            window.dispatchEvent(appDataEvent);
        };
