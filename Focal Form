import React, { memo, useState, useEffect, useRef } from "react";
import { Button, TextField, Typography } from "@mui/material";
import { useDispatch } from "react-redux";
import EasaListService from "../../EasaRegisterListService";
import "./FocalForm.scss";
import { MasterDataItem } from "../AdminModal";
import { showSnackbar } from "../../../../../core/snackbar/CustomSnackBarSlice";

interface FocalData {
    ID?: number;
    NAME?: string;
    ADDRESS?: string;
    PHONENO?: number;
    EMAIL?: string;
    POSITION?: string;
    TITLE?: string;
    ISACTIVE?: boolean;
}

interface FocalFormProps {
    focalData?: FocalData;
    saveFocal?: () => void;
    fetchFocal: () => void;
    focalList?: FocalData[];
    cancelFocal?: (id: number) => void;
    savedFormData?: any;
    onFormChange?: (data: any) => void;
    clearFormData?: () => void;
}

const FocalForm: React.FC<FocalFormProps> = memo(({ focalData, saveFocal, fetchFocal, cancelFocal, focalList = [], savedFormData, onFormChange, clearFormData }) => {

    const dispatch = useDispatch();
    const debounceTimer = useRef<any>(null);
    const initializedRef = useRef(false);

    const [formData, setFormData] = useState(() => {
        if (savedFormData) {
            return savedFormData;
        }
        if (focalData) {
            return {
                id: (focalData as any)?.newFlag ? 0 : (focalData.ID ?? 0),
                name: focalData.NAME ?? "",
                address: focalData.ADDRESS ?? "",
                phone: String(focalData.PHONENO ?? ""),
                email: focalData.EMAIL ?? "",
                position: focalData.POSITION ?? "",
                title: focalData.TITLE ?? "",
                isActive: focalData.ISACTIVE ?? false
            };
        }
        return {
            id: 0,
            name: "",
            address: "",
            phone: "",
            email: "",
            position: "",
            title: "",
            isActive: false
        };
    });

    useEffect(() => {
        return () => {
            if (debounceTimer.current) clearTimeout(debounceTimer.current);
        };
    }, []);

    const handleChange = (e: any) => {
        const updated = {
            ...formData,
            [e.target.name]: e.target.value
        };
        setFormData(updated);

        if (debounceTimer.current) clearTimeout(debounceTimer.current);
        debounceTimer.current = setTimeout(() => {
            onFormChange?.(updated);
        }, 400);
    };

    const handleCancel = () => {
        clearFormData?.();

        if (debounceTimer.current) clearTimeout(debounceTimer.current);

        if ((focalData as any)?.newFlag) {
            setFormData({
                id: 0,
                name: "",
                address: "",
                phone: "",
                email: "",
                position: "",
                title: "",
                isActive: false
            });
        } else {
            setFormData({
                id: focalData?.ID ?? 0,
                name: focalData?.NAME ?? "",
                address: focalData?.ADDRESS ?? "",
                phone: String(focalData?.PHONENO ?? ""),
                email: focalData?.EMAIL ?? "",
                position: focalData?.POSITION ?? "",
                title: focalData?.TITLE ?? "",
                isActive: focalData?.ISACTIVE ?? false
            });
        }

        if (cancelFocal && focalData?.ID !== undefined) {
            cancelFocal(focalData.ID);
        }
    };

    const handleSave = async () => {

        if (!formData.name || formData.name.trim() === "") {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Focal Name is required."
            }));
            return;
        }

        const isDuplicate = focalList?.some(
            (item: FocalData) =>
                item.NAME?.trim().toLowerCase() === formData.name.trim().toLowerCase() &&
                item.ID !== formData.id
        );

        if (isDuplicate) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Focal Name must be unique."
            }));
            return;
        }

        if (formData.phone && !/^\d+$/.test(formData.phone)) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Invalid Phone Number"
            }));
            return;
        }

        const items: MasterDataItem[] = [];

        items.push({
            Id: formData.id ?? 0,
            OperationType: formData.id ? "update" : "add",
            Name: formData.name.trim(),
            Description: "",
            IsActive: formData.isActive ? "Y" : "N",
            Notes: "",
            Address: formData.address ?? "",
            Department: formData.position ?? "",
            Phone: formData.phone ?? "",
            Email: formData.email ?? "",
            Title: formData.title ?? "",
            orgTypeId: 0
        });

        const payload = {
            MasterDataType: "Focal Management",
            Items: items
        };

        try {
            const response = await EasaListService.addMasterDataType(payload);
            if (response?.data === -1) {
                dispatch(showSnackbar({
                    snackbarOpen: true,
                    snackbarType: "error",
                    snackbarMessage: "Error in saving the data."
                }));
                return;
            }

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Focal saved successfully."
            }));

            fetchFocal?.();
            clearFormData?.();
            handleCancel();

        } catch (error) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Error saving Focal."
            }));
            console.error("Error saving focal:", error);
        }
    };

    return (
        <div style={{ padding: "10px" }}>

            <div className="form-header">
                {formData.id ? "Edit Focal" : "Add Focal"}
            </div>

            <div className="form-grid">

                {/* LEFT SIDE */}
                <div className="form-column">

                    <div className="form-row">
                        <label>Focal Name</label>
                        <TextField
                            name="name"
                            value={formData.name}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Address</label>
                        <TextField
                            name="address"
                            value={formData.address}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Position</label>
                        <TextField
                            name="position"
                            value={formData.position}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                </div>

                {/* RIGHT SIDE */}
                <div className="form-column">

                    <div className="form-row">
                        <label>Phone Number</label>
                        <TextField
                            name="phone"
                            value={formData.phone}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Email</label>
                        <TextField
                            name="email"
                            value={formData.email}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Title</label>
                        <TextField
                            name="title"
                            value={formData.title}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                </div>

            </div>

            <div className="form-actions">
                <Typography id="modal-modal-btn" className='buttonSection' sx={{ mt: 2 }} textAlign={'end'} style={{ display: 'flex', justifyContent: 'flex-end', gap: '10px', paddingBlock: '0px', paddingInline: '0px', marginTop: '10px' }}>
                    <Button variant="outlined" size="small" onClick={handleCancel} className={"cancelButtonUserDefined"}>Cancel</Button>
                    <Button variant="contained" size="small" onClick={handleSave} className="deleteButton">Save</Button>
                </Typography>
            </div>

        </div>
    );
});

export default FocalForm;
