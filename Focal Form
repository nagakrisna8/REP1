            return null;
        });

        storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, true);
        setIsTabDirty(true);
    };

    const handleChange = (event: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement>, targetContent: string, newDataToInsert: string, content: string) => {
        const updates: Partial<SupportingRowWiseDetails> = {};
        let originalPlainText = content ? htmlToText(content, { wordwrap: false }) : "";
        let updatedPlainText = newDataToInsert ? htmlToText(newDataToInsert, { wordwrap: false }) : "";
        if (targetContent === 'DocumentTitle') {
            updates.DocumentTitle = newDataToInsert;
        } else if (targetContent === 'Notes') {
            updates.Notes = newDataToInsert;
        };

        // Check if 'headerData' is defined and has at least one element, and ensure 'csrData[0]' and its 'STATE' are valid
        if (props && props.headerData && props.headerData?.WorkFlowStep !== ReportStepId.CREATE_STEP) {
            // Only proceed if 'updatedPlainText' and 'originalPlainText' are different
            if (updatedPlainText === originalPlainText) {
                setRowWiseRefData((prev) => {
                    if (prev) {
                        return {
                            ...prev,
                            ...updates
                        };
                    }
                    return null;
                });
                setIsTabDirty(false);
            } else {
                let tempCategories = JSON.parse(JSON.stringify(getRowWiseRefData));
                setRowWiseRefData(null);
                tempReferencesRef.current = null;
                setTimeout(() => {
                    setRowWiseRefData(tempCategories);
                    tempReferencesRef.current = tempCategories;
                });
            }
        } else {
            setRowWiseRefData((prev) => {
                if (prev) {
                    tempReferencesRef.current = { ...prev, ...updates };
                    return {
                        ...prev,
                        ...updates
                    };
                }
                return null;
            });
            storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, true);
            setIsTabDirty(true);
        }
