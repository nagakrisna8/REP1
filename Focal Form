import { Autocomplete, Badge, Button, Checkbox, FormControl, Grid, IconButton, ListItemText, MenuItem, OutlinedInput, Select, SelectChangeEvent, TextField } from "@mui/material";
import React, { useState, useEffect, useRef, useMemo, useImperativeHandle } from "react";
import { ConfigRefDocDetails, ConfigRefDtl, ControlCommentCount, ControlsDtls, FixedTabTitle, GetReasonCodeData, GetRegulationPurposeData, GetStatus, OperationType, RefDocGridDetails, ReferenceDataSourceName, ReportStepId, ReportType, RevisionListDetails, SupportingRowWiseDetails, TagDetails, ToolsEnum } from "../../../../../../../model/Model";
import SpeakerNotesOutlinedIcon from '@mui/icons-material/SpeakerNotesOutlined';
import './ManageReferenceData.scss';
import ReferenceDataGridService from "../ReferenceDataGridService";
import { useLocation, useNavigate, useParams, useSearchParams } from "react-router-dom";
import { userDefinedConfirm } from "../../../../../../../utils/ConfirmDialog";
import KendoEditor from "../../../dynamic-tabs/k-editor-wrapper/KendoEditor.component";
import { htmlToText } from "html-to-text";
import { showSnackbar } from "../../../../../../core/snackbar/CustomSnackBarSlice";
import { useDispatch } from "react-redux";
import ManageReferenceDataService from "./ManageReferenceDataService";
import CommentHistoryPopup from "../../../dynamic-tabs/comment-history-popup/CommentHistoryPopup";
import EnvDetail from "../../../../../../../utils/EnvDetail";
