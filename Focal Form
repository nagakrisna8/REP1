$text-default: #253746;
$table-header-bg: #ffffff;
$table-bg-alt-row: #eff6fa;
$table-row-bg-hover: #dce2e6;
$table-row-border-col: #ededed;
$grid-topbar-height: 48px;
$table-row-height: 32px;
$text-size-default: 14px;

.EASA-Admin-table-maintenance {
  font-size: $text-size-default;

  .EASA-Admin-table-maintenance-topbar {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-left: 22px;
    gap: 8px;
    color: $text-default;
  }

  .MuiPopover-paper {
    height: 170px !important;
  }

  #admin-table-page-selector,
  #admin-table-categorytype-selector {
    margin: 0px;
    padding: 4px 8px;
  }

  #admin-table-categorytype-selector {
    width: 147px;
  }

  .EASA-Admin-table-maintenance-section {
    margin-top: 16px;
  }

  .hideCls {
    display: none !important;
  }

  /* ✅ FIX: Prevent grid from stretching */
  .k-grid-content table {
    width: auto !important;
    min-width: unset !important;
  }

  .k-table {
    table-layout: auto !important;
  }

  /* ✅ FIX: Completely remove hierarchy column space */
  .focal-grid-compact.k-grid {
    .k-hierarchy-col,
    .k-hierarchy-cell {
      width: 0 !important;
      min-width: 0 !important;
      max-width: 0 !important;
      padding: 0 !important;
      border: none !important;
      display: none !important;
    }
  }

  /* Existing grid height controls */
  #kgrid-oss-checklistType,
  #kgrid-oss-admin-table-errorCode1,
  #kgrid-oss-admin-table-errorCode1-itar,
  #kgrid-oss-admin-table-errorCode2,
  #kgrid-oss-admin-table-errorCode3,
  #kgrid-oss-admin-table-category,
  #kgrid-oss-admin-table-category-type,
  #kgrid-oss-admin-table-reasonCode,
  #kgrid-oss-admin-table-reasonCode-itar {
    min-height: 130px;
    max-height: inherit !important;

    td,
    th {
      color: $text-default;
    }

    th {
      padding-block: 0 !important;
      height: $table-row-height !important;
    }

    .k-table-alt-row {
      background-color: $table-bg-alt-row !important;
    }

    tbody tr:hover {
      background-color: $table-row-bg-hover !important;
    }

    tbody tr td {
      border-bottom: 1px solid $table-row-border-col !important;
      padding: 0 8px !important;
      height: $table-row-height !important;
    }
  }

  /* Buttons */
  #kgrid-oss-checklistType td .deleteBtn,
  #kgrid-oss-admin-table-errorCode1 td .deleteBtn,
  #kgrid-oss-admin-table-errorCode2 td .deleteBtn {
    padding: 0.2em 1.5em !important;
    height: 32px !important;
    border: 1px solid #a19b9b !important;
    color: #5a5a5a !important;
    font-weight: bold;
    border-radius: 4px !important;
    background: #ffffff;
  }

  /* Remove hover white override */
  .focal-grid-compact {
    --kendo-grid-row-hover-bg: #ffffff;
  }

  /* Selection fix */
  .k-grid tr.k-selected,
  .k-grid tr.k-focus {
    background-color: transparent !important;
  }

  .k-grid td.k-focus {
    box-shadow: none !important;
    background-color: transparent !important;
  }

  /* Hide toolbar icons */
  .k-button-md.k-icon-button {
    display: none !important;
  }
}

/* External styles */

.css-106ttss-MuiSelect-select-MuiInputBase-input-MuiOutlinedInput-input {
  background-color: #fafafa !important;
}

.admin-topbarmain-height-grid {
  height: 130px !important;
}

.admin-supplier-topbarmain-height-grid {
  height: 70px !important;
}

/* Compact spacing */
.focal-grid td,
.focal-grid .k-table-td {
  padding-block: 0.5rem !important;
  padding-inline: 0.75rem !important;
  line-height: 1.4;
}
