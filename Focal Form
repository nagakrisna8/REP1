import React, { memo, useState, useEffect, useRef } from "react";
import { Button, TextField, Typography } from "@mui/material";
import { useDispatch } from "react-redux";
import EasaListService from "../../EasaRegisterListService";
import "./FocalForm.scss";
import { MasterDataItem } from "../AdminModal";
import { showSnackbar } from "../../../../../core/snackbar/CustomSnackBarSlice";

interface FocalData {
    ID?: number;
    NAME?: string;
    ADDRESS?: string;
    PHONE?: number;
    EMAIL?: string;
    DEPARTMENT?: string;
    TITLE?: string;
    ISACTIVE?: boolean;
    ISBEMS?: string; // <-- IMPORTANT (if backend supports)
}

interface UserData {
    Email?: string;
    Phone?: string | number;
    Name?: string;
    Bemsid?: Number;
    ActiveFlag?: string;
}

interface FocalFormProps {
    focalData?: FocalData;
    userData?: UserData[];
    saveFocal?: () => void;
    fetchFocal: (orgId: number, orgTypeId: number) => void;
    focalList?: FocalData[];
    cancelFocal?: (id: number) => void;
    savedFormData?: any;
    onFormChange?: (data: any) => void;
    clearFormData?: () => void;
    setDirtyFlag?: (flag: boolean) => void;
    selectedOrgId: any;
    selectedOrganizationId: any;
}

const FocalForm: React.FC<FocalFormProps> = memo(({
    focalData,
    saveFocal,
    fetchFocal,
    cancelFocal,
    focalList = [],
    savedFormData,
    onFormChange,
    clearFormData,
    selectedOrgId,
    selectedOrganizationId,
    setDirtyFlag,
    userData = []
}) => {

    const dispatch = useDispatch();
    const debounceTimer = useRef<any>(null);

    const [formData, setFormData] = useState({
        id: 0,
        name: "",
        address: "",
        phone: "",
        email: "",
        position: "",
        title: "",
        isActive: false,
        isBemsRecord: false
    });

    const isBemsUser = formData.isBemsRecord;

    // ✅ MAIN EFFECT (Handles Add / Edit / BEMS / Reset)
    useEffect(() => {

        if (savedFormData) {
            setFormData(savedFormData);
            return;
        }

        // CREATE NEW
        if ((focalData as any)?.newFlag) {

            // BEMS SEARCH RESULT
            if (userData && userData.length > 0) {
                const user = userData[0];

                const updatedData = {
                    id: user.Bemsid ?? 0,
                    name: user.Name ?? "",
                    address: "",
                    phone: String(user.Phone ?? ""),
                    email: user.Email ?? "",
                    position: "",
                    title: "",
                    isActive: user.ActiveFlag === "Y",
                    isBemsRecord: true
                };

                setFormData(updatedData);
                onFormChange?.(updatedData);
            } else {
                // EMPTY NEW FORM
                const emptyData = {
                    id: 0,
                    name: "",
                    address: "",
                    phone: "",
                    email: "",
                    position: "",
                    title: "",
                    isActive: false,
                    isBemsRecord: false
                };

                setFormData(emptyData);
                onFormChange?.(emptyData);
            }
            return;
        }

        // EDIT MODE
        if (focalData) {
            const editData = {
                id: focalData.ID ?? 0,
                name: focalData.NAME ?? "",
                address: focalData.ADDRESS ?? "",
                phone: String(focalData.PHONE ?? ""),
                email: focalData.EMAIL ?? "",
                position: focalData.DEPARTMENT ?? "",
                title: focalData.TITLE ?? "",
                isActive: focalData.ISACTIVE ?? false,
                isBemsRecord: focalData.ISBEMS === "Y"
            };

            setFormData(editData);
            onFormChange?.(editData);
            return;
        }

        // FALLBACK RESET
        setFormData({
            id: 0,
            name: "",
            address: "",
            phone: "",
            email: "",
            position: "",
            title: "",
            isActive: false,
            isBemsRecord: false
        });

    }, [focalData, savedFormData, userData]);

    // CLEANUP
    useEffect(() => {
        return () => {
            if (debounceTimer.current) clearTimeout(debounceTimer.current);
        };
    }, []);

    const handleChange = (e: any) => {
        const updated = {
            ...formData,
            [e.target.name]: e.target.value
        };
        setFormData(updated);

        if (debounceTimer.current) clearTimeout(debounceTimer.current);
        debounceTimer.current = setTimeout(() => {
            onFormChange?.(updated);
        }, 400);
    };

    const handleCancel = () => {
        clearFormData?.();

        if (debounceTimer.current) clearTimeout(debounceTimer.current);

        if ((focalData as any)?.newFlag) {
            setFormData({
                id: 0,
                name: "",
                address: "",
                phone: "",
                email: "",
                position: "",
                title: "",
                isActive: false,
                isBemsRecord: false
            });
        } else {
            setFormData({
                id: focalData?.ID ?? 0,
                name: focalData?.NAME ?? "",
                address: focalData?.ADDRESS ?? "",
                phone: String(focalData?.PHONE ?? ""),
                email: focalData?.EMAIL ?? "",
                position: focalData?.DEPARTMENT ?? "",
                title: focalData?.TITLE ?? "",
                isActive: focalData?.ISACTIVE ?? false,
                isBemsRecord: focalData?.ISBEMS === "Y"
            });
        }

        if (cancelFocal && focalData?.ID !== undefined) {
            cancelFocal(focalData.ID);
        }
    };

    const handleSave = async () => {

        if (!formData.name.trim()) {
            dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "error", snackbarMessage: "Focal Name is required." }));
            return;
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (formData.email && !emailRegex.test(formData.email)) {
            dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "error", snackbarMessage: "Invalid Email Address" }));
            return;
        }

        if (formData.phone && !/^\+?[0-9 ()-]+$/.test(formData.phone.trim())) {
            dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "error", snackbarMessage: "Invalid Phone Number" }));
            return;
        }

        const items: MasterDataItem[] = [{
            Id: formData.id ?? 0,
            OperationType: (focalData as any)?.newFlag ? "add" : "update",
            Name: formData.name.trim(),
            IsActive: formData.isActive ? "Y" : "N",
            Address: formData.address ?? "",
            Department: formData.position ?? "",
            Phone: formData.phone ?? "",
            Email: formData.email ?? "",
            Title: formData.title ?? "",
            orgTypeId: selectedOrgId ?? 0,
            orgId: selectedOrganizationId ?? 0,
        }];

        const payload = {
            MasterDataType: "Focal Management",
            Items: items
        };

        try {
            await EasaListService.addMasterDataType(payload);

            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Focal saved successfully."
            }));

            clearFormData?.();
            setDirtyFlag?.(false);

            if (cancelFocal && focalData?.ID !== undefined) {
                cancelFocal(focalData.ID);
            }

            fetchFocal?.(selectedOrgId, selectedOrganizationId);

        } catch {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Error saving Focal."
            }));
        }
    };

    return (
        <div style={{ padding: "10px" }}>

            <div className="form-header">
                {formData.id ? "Edit Focal" : "Add Focal"}
            </div>

            <div className="form-grid">

                <div className="form-column">
                    <div className="form-row">
                        <label>Focal Name</label>
                        <TextField name="name" value={formData.name} onChange={handleChange} size="small" fullWidth disabled={isBemsUser} />
                    </div>

                    <div className="form-row">
                        <label>Address</label>
                        <TextField name="address" value={formData.address} onChange={handleChange} size="small" fullWidth />
                    </div>

                    <div className="form-row">
                        <label>Position</label>
                        <TextField name="position" value={formData.position} onChange={handleChange} size="small" fullWidth />
                    </div>
                </div>

                <div className="form-column">
                    <div className="form-row">
                        <label>Phone Number</label>
                        <TextField name="phone" value={formData.phone} onChange={handleChange} size="small" fullWidth disabled={isBemsUser} />
                    </div>

                    <div className="form-row">
                        <label>Email</label>
                        <TextField name="email" value={formData.email} onChange={handleChange} size="small" fullWidth disabled={isBemsUser} />
                    </div>

                    <div className="form-row">
                        <label>Title</label>
                        <TextField name="title" value={formData.title} onChange={handleChange} size="small" fullWidth />
                    </div>
                </div>

            </div>

            <div className="form-actions">
                <Typography sx={{ mt: 2 }} textAlign={'end'} style={{ display: 'flex', justifyContent: 'flex-end', gap: '10px' }}>
                    <Button variant="outlined" size="small" onClick={handleCancel}>Cancel</Button>
                    <Button variant="contained" size="small" onClick={handleSave}>Save</Button>
                </Typography>
            </div>

        </div>
    );
});

export default FocalForm;
